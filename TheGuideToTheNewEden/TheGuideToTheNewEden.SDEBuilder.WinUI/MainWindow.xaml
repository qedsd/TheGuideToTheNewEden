<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="TheGuideToTheNewEden.SDEBuilder.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:TheGuideToTheNewEden.SDEBuilder.WinUI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="SDEBuilder"
    mc:Ignorable="d">

    <Grid Padding="8">
        <Grid x:Name="SettingGrid">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Width="80"
                        VerticalAlignment="Center"
                        Text="SDE Folder" />
                    <TextBox
                        x:Name="SDEFolder"
                        Grid.Column="1"
                        Margin="4,0"
                        VerticalAlignment="Center" />
                    <Button
                        x:Name="PickSDEFolder"
                        Grid.Column="2"
                        VerticalAlignment="Center"
                        Click="PickSDEFolder_Click"
                        Content="+" />
                </Grid>
                <Grid Grid.Row="1" Margin="0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Width="80"
                        VerticalAlignment="Center"
                        Text="Database File" />
                    <TextBox
                        x:Name="SaveDB"
                        Grid.Column="1"
                        Margin="4,0"
                        VerticalAlignment="Center" />
                    <Button
                        x:Name="PickSaveDB"
                        Grid.Column="2"
                        VerticalAlignment="Center"
                        Click="PickSaveDB_Click"
                        Content="+" />
                </Grid>
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Width="80"
                        VerticalAlignment="Center"
                        Text="Language" />
                    <ComboBox
                        x:Name="LangComboBox"
                        Grid.Column="1"
                        Margin="4,0,0,0"
                        SelectedIndex="1">
                        <ComboBoxItem>De</ComboBoxItem>
                        <ComboBoxItem>En</ComboBoxItem>
                        <ComboBoxItem>Es</ComboBoxItem>
                        <ComboBoxItem>Fr</ComboBoxItem>
                        <ComboBoxItem>Ja</ComboBoxItem>
                        <ComboBoxItem>Ko</ComboBoxItem>
                        <ComboBoxItem>Ru</ComboBoxItem>
                        <ComboBoxItem>Zh</ComboBoxItem>
                    </ComboBox>
                </Grid>
            </Grid>

            <Grid Grid.Row="1" Margin="0,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition />
                </Grid.RowDefinitions>
                <CheckBox
                    Margin="8,0,0,0"
                    Checked="SelectAll_Checked"
                    Content="Select All"
                    IsChecked="True"
                    Unchecked="SelectAll_Unchecked" />
                <GridView
                    x:Name="FilesListView"
                    Grid.Row="1"
                    BorderBrush="Gray"
                    BorderThickness="1">
                    <GridView.ItemContainerStyle>
                        <Style BasedOn="{StaticResource DefaultGridViewItemStyle}" TargetType="GridViewItem">
                            <Setter Property="Width" Value="200" />
                            <Setter Property="HorizontalContentAlignment" Value="Left" />
                            <Setter Property="Padding" Value="8,0" />
                        </Style>
                    </GridView.ItemContainerStyle>
                    <GridView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <CheckBox Content="{Binding File, Converter={StaticResource FileToNameConverter}}" IsChecked="{Binding Checked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>
            </Grid>

            <StackPanel
                Grid.Row="2"
                Margin="0,8"
                HorizontalAlignment="Center"
                Orientation="Horizontal">
                <Button
                    Width="100"
                    Margin="4,0"
                    Click="RefreshButton_Click"
                    Content="Refresh" />
                <Button
                    Width="100"
                    Margin="4,0"
                    Click="StartButton_Click"
                    Content="Start"
                    Style="{ThemeResource AccentButtonStyle}" />
            </StackPanel>
        </Grid>
        <Grid
            x:Name="WaitingGrid"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            Background="#96FFFFFF"
            Visibility="Collapsed">
            <ProgressRing
                x:Name="WaitingRing"
                IsActive="False"
                Visibility="Collapsed" />
        </Grid>
    </Grid>
</Window>
