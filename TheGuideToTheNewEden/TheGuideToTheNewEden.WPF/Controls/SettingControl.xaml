<UserControl
    x:Class="TheGuideToTheNewEden.WPF.Controls.SettingControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:TheGuideToTheNewEden.WPF.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Height="70"
    d:DesignHeight="450"
    d:DesignWidth="800"
    Foreground="{DynamicResource DefaultForegroundBrush}"
    mc:Ignorable="d">
    <Grid Background="Transparent">
        <Border
            Padding="16,4"
            Background="{DynamicResource SecondBackgroudBrush}"
            CornerRadius="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <ContentPresenter
                    x:Name="IconPresenter"
                    Grid.Column="0"
                    Width="20"
                    Height="20"
                    Margin="10,5,10,5"
                    VerticalAlignment="Center"
                    Content="{Binding Icon, Mode=OneWay, RelativeSource={RelativeSource AncestorType=UserControl}}" />

                <Grid
                    Grid.Column="1"
                    Margin="12"
                    VerticalAlignment="Center">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock
                        x:Name="Title"
                        FontSize="14"
                        Text="{Binding SettingTitle, Mode=OneWay, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                    <TextBlock
                        x:Name="Description"
                        Grid.Row="1"
                        Margin="0,4,0,0"
                        FontSize="12"
                        Text="{Binding SettingDescription, Mode=OneWay, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                </Grid>


                <ContentPresenter
                    x:Name="ContentPresenter"
                    Grid.Column="2"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Content="{Binding SettingContent, Mode=OneWay, RelativeSource={RelativeSource AncestorType=UserControl}}" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
