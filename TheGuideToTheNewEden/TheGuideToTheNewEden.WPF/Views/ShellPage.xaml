<Page
    x:Class="TheGuideToTheNewEden.WPF.Views.ShellPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:TheGuideToTheNewEden.WPF.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="ShellPage"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <!--  导航  -->
        <Grid Margin="16,0,16,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <!--  标题  -->
            <StackPanel Orientation="Horizontal">
                <Image
                    Width="20"
                    ImageFailed="Image_ImageFailed"
                    Source="/TheGuideToTheNewEden.WPF;component/Resources/Images/logo_128.png" />
                <TextBlock
                    Margin="8,0,0,0"
                    VerticalAlignment="Center"
                    FontWeight="Heavy"
                    Text="{StaticResource AppDisplayName}" />
            </StackPanel>
        </Grid>
        <!--  内容  -->
        <Frame Grid.Column="1" />
    </Grid>
</Page>
