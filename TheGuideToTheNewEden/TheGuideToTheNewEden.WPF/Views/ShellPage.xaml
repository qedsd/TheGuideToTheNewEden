<UserControl
    x:Class="TheGuideToTheNewEden.WPF.Views.ShellPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:TheGuideToTheNewEden.WPF.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:TheGuideToTheNewEden.WPF.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
    d:DesignHeight="450"
    d:DesignWidth="800"
    Foreground="{DynamicResource DefaultForegroundBrush}"
    mc:Ignorable="d">

    <Grid Margin="0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="190" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <!--  导航  -->
        <Grid Margin="8,16,8,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="50" />
                <RowDefinition />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <!--  标题  -->
            <StackPanel
                Margin="0,10,0,0"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Orientation="Horizontal">
                <svgc:SvgViewbox Width="16" Source="/Resources/Images/logo.svg" />
                <TextBlock
                    Margin="10,0,0,0"
                    VerticalAlignment="Center"
                    FontFamily="Calibri "
                    FontSize="16"
                    FontWeight="Heavy"
                    Text="{DynamicResource AppDisplayName}" />
            </StackPanel>
            <!--  菜单  -->
            <ListBox
                x:Name="MenuList"
                Grid.Row="1"
                Margin="0,0"
                Background="Transparent"
                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                ScrollViewer.VerticalScrollBarVisibility="Hidden"
                SelectedIndex="0"
                SelectionChanged="MenuList_SelectionChanged"
                SelectionMode="Single">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border x:Name="border">
                            <TextBlock Margin="8,0" Text="{Binding Title, Mode=OneWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DynamicResourceFromBindingConverter}}" />
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.Resources>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Foreground" Value="{DynamicResource SecondaryForegroundBrush}" />
                        <Setter Property="FontSize" Value="14" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border
                                        x:Name="Border"
                                        Padding="16,12"
                                        Background="Transparent">
                                        <ContentPresenter />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Foreground" Value="{DynamicResource DefaultForegroundBrush}" />
                                            <Setter Property="FontSize" Value="14" />
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Foreground" Value="{DynamicResource DefaultForegroundBrush}" />
                                            <Setter Property="FontSize" Value="14" />
                                            <Setter Property="FontWeight" Value="Heavy" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.Resources>
            </ListBox>
            <!--  Footer  -->
            <StackPanel
                Grid.Row="2"
                Margin="0,16,0,8"
                HorizontalAlignment="Center"
                Orientation="Horizontal">
                <StackPanel.Resources>
                    <Style TargetType="TextBlock">
                        <Setter Property="FontSize" Value="11" />
                        <Setter Property="VerticalAlignment" Value="Center" />
                        <Setter Property="Foreground" Value="{DynamicResource SecondaryForegroundBrush}" />
                    </Style>
                </StackPanel.Resources>
                <Button Padding="6,6" Style="{DynamicResource TransparentButton}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="v" />
                        <TextBlock x:Name="VersionTextBlock" Text="3.0.0.0" />
                    </StackPanel>
                </Button>
                <Button Padding="6,6" Style="{DynamicResource TransparentButton}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="by " />
                        <TextBlock Text="QEDSD" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
        <!--  内容  -->
        <Border
            Grid.Column="1"
            Padding="4,34,4,4"
            Background="{DynamicResource DefaultBackgroudBrush}"
            CornerRadius="0">
            <Grid>
                <Frame x:Name="ContentFrame" />
                <controls:LoadingControl
                    x:Name="Loading"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    IsLoading="False" />
                <controls:InfoBarControl
                    x:Name="InfoBar"
                    Margin="0,0,0,16"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Visibility="Collapsed" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
