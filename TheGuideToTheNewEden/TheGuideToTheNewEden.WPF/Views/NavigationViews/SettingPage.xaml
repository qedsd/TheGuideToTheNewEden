<Page
    x:Class="TheGuideToTheNewEden.WPF.Views.NavigationViews.SettingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:TheGuideToTheNewEden.WPF.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ic="clr-namespace:FluentIcons.Wpf;assembly=FluentIcons.Wpf"
    xmlns:local="clr-namespace:TheGuideToTheNewEden.WPF.Views.NavigationViews"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="SettingPage"
    d:DesignHeight="450"
    d:DesignWidth="800"
    Foreground="{DynamicResource DefaultForegroundBrush}"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal">
            <Button
                Click="FirstSetting_Clicked"
                Content="{DynamicResource Navigation.SettingPage}"
                FontSize="24"
                Style="{StaticResource TransparentButton}" />
            <StackPanel
                x:Name="SecondSetting"
                Orientation="Horizontal"
                Visibility="Collapsed">
                <ic:FluentIcon
                    Icon="ChevronRight"
                    IconSize="Resizable"
                    IconVariant="Regular" />
                <Button
                    Content="{Binding Selected.Title, Mode=OneWay, Converter={StaticResource DynamicResourceFromBindingConverter}, RelativeSource={RelativeSource AncestorType=Page}}"
                    FontSize="24"
                    Style="{StaticResource TransparentButton}" />
            </StackPanel>
        </StackPanel>
        <ListBox
            x:Name="SettingList"
            Grid.Row="1"
            Background="Transparent"
            ItemsSource="{Binding SettingItems, Mode=OneWay, RelativeSource={RelativeSource AncestorType=Page}}"
            MouseLeftButtonUp="ListBox_MouseLeftButtonUp"
            Style="{StaticResource SettingListBox}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <controls:SettingControl
                        VerticalAlignment="Bottom"
                        Icon="{Binding Icon}"
                        SettingDescription="{Binding Description, Mode=OneWay, Converter={StaticResource DynamicResourceFromBindingConverter}}"
                        SettingTitle="{Binding Title, Mode=OneWay, Converter={StaticResource DynamicResourceFromBindingConverter}}">
                        <controls:SettingControl.SettingContent>
                            <ic:FluentIcon
                                Icon="ChevronRight"
                                IconSize="Resizable"
                                IconVariant="Regular" />
                        </controls:SettingControl.SettingContent>
                    </controls:SettingControl>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <Frame
            x:Name="SettingFrame"
            Grid.Row="1"
            Background="Transparent"
            Visibility="Collapsed" />
    </Grid>
</Page>
