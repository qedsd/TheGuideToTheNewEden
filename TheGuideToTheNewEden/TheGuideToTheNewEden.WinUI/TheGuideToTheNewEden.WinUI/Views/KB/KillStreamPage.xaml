                            Command="{x:Bind VM.ClearListCommand}"
                            Icon="Clear"
                            Label="{StaticResource General_Clear}" />
                        <AppBarButton
                            x:Name="Button_Setting"
                            Margin="8,0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Click="Button_Setting_Click"
                            Icon="Setting"
                            Label="{StaticResource General_Setting}" />
                    </StackPanel>
                    <StackPanel
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <winui:FluentIcon Margin="0,0,8,0" Icon="Filter" />
                        <TextBlock Text="{x:Bind VM.PassedCount, Mode=OneWay}" ToolTipService.ToolTip="{StaticResource ZKBHomePage_MatchedCount}" />
                        <TextBlock Margin="2,0" Text="/" />
                        <TextBlock Text="{x:Bind VM.TotalReceivedCount, Mode=OneWay}" ToolTipService.ToolTip="{StaticResource ZKBHomePage_TotalReceivedCount}" />
                    </StackPanel>
                </Grid>
            </controls:CardControl.Fonter>
        </controls:CardControl>
    </Grid>
</Page>
