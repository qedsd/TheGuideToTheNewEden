<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="TheGuideToTheNewEden.WinUI.Views.KB.KillStreamPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:TheGuideToTheNewEden.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:kb="using:TheGuideToTheNewEden.WinUI.ViewModels.KB"
    xmlns:local="using:TheGuideToTheNewEden.WinUI.Views.KB"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="Transparent"
    mc:Ignorable="d">
    <Page.DataContext>
        <kb:ZKBKillStreamViewModel x:Name="VM" />
    </Page.DataContext>
    <Grid Background="{ThemeResource TransparentBackgroudBrush}" CornerRadius="4">
        <controls:CardControl>
            <controls:CardControl.CustomContent>
                <Grid>
                    <Grid x:Name="DisconnectGrid">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Text="{StaticResource ZKBHomePage_DisconnectTip}" />
                    </Grid>
                    <Grid x:Name="ConnectedGrid" Visibility="Collapsed">
                        <controls:KBListControl
                            x:Name="KBListControl"
                            IdNameClicked="KBListControl_IdNameClicked"
                            KBs="{x:Bind VM.KBItemInfos, Mode=OneWay}"
                            OnItemClicked="KBListControl_OnItemClicked" />
                    </Grid>
                    <Grid x:Name="SettingGrid" Visibility="Collapsed">
                        <Grid>
                            <controls:CardControl>
                                <controls:CardControl.Header>
                                    <SelectorBar SelectionChanged="Setting_SelectionChanged">
                                        <SelectorBarItem
                                            IsSelected="True"
                                            Tag="0"
                                            Text="{StaticResource ZKBHomePage_Setting_Filter}" />
                                        <SelectorBarItem Tag="1" Text="{StaticResource ZKBHomePage_Setting_Notify}" />
                                    </SelectorBar>
                                </controls:CardControl.Header>
                                <controls:CardControl.CustomContent>
                                    <Grid>
                                        <Grid x:Name="FilterSetting">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition />
                                                <ColumnDefinition Width="8" />
                                                <ColumnDefinition />
                                            </Grid.ColumnDefinitions>
                                            <controls:CardControl Grid.Column="0">
                                                <controls:CardControl.Header>
                                                    <TextBlock Text="{StaticResource MapIntelTool_Exclusions}" ToolTipService.ToolTip="{StaticResource MapIntelTool_Exclusions_Tip}" />
                                                </controls:CardControl.Header>
                                                <controls:CardControl.CustomContent>
                                                    <Grid Margin="8">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition />
                                                        </Grid.RowDefinitions>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock VerticalAlignment="Center" Text="{StaticResource General_Add}" />
                                                            <controls:IdNameSearchBox
                                                                x:Name="ExclusionsIdNameSearchBox"
                                                                Grid.Column="1"
                                                                Margin="8,0,0,0" />
                                                        </Grid>
                                                        <ListView
                                                            Grid.Row="1"
                                                            Margin="0,8,0,0"
                                                            BorderBrush="{ThemeResource GrayBrush}"
                                                            BorderThickness="1"
                                                            ItemsSource="{x:Bind VM.Config.Exclusions, Mode=OneWay}"
                                                            SelectionMode="Single"
                                                            Style="{StaticResource StretchListView}">
                                                            <ListView.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition />
                                                                            <ColumnDefinition Width="Auto" />
                                                                            <ColumnDefinition Width="Auto" />
                                                                        </Grid.ColumnDefinitions>
                                                                        <TextBlock
                                                                            VerticalAlignment="Center"
                                                                            Text="{Binding Name}"
                                                                            TextTrimming="CharacterEllipsis"
                                                                            ToolTipService.ToolTip="{Binding Id}" />
                                                                        <TextBlock
                                                                            Grid.Column="1"
                                                                            VerticalAlignment="Center"
                                                                            FontSize="12"
                                                                            Text="{Binding Category, Converter={StaticResource CategoryEnumToStringConverter}}" />
                                                                        <Button
                                                                            Grid.Column="2"
                                                                            Margin="8,0,0,0"
                                                                            Click="DeleteExclusions_Click"
                                                                            Content="×"
                                                                            FontSize="16"
                                                                            Foreground="{ThemeResource RedBrush}"
                                                                            Style="{StaticResource TransparentButton}" />
                                                                    </Grid>
                                                                </DataTemplate>
                                                            </ListView.ItemTemplate>
                                                        </ListView>
                                                    </Grid>
                                                </controls:CardControl.CustomContent>
                                            </controls:CardControl>
                                            <controls:CardControl Grid.Column="2">
                                                <controls:CardControl.Header>
                                                    <TextBlock Text="{StaticResource MapIntelTool_Inclusions}" ToolTipService.ToolTip="{StaticResource MapIntelTool_Inclusions_Tip}" />
                                                </controls:CardControl.Header>
                                                <controls:CardControl.CustomContent>
                                                    <Grid Margin="8">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition />
                                                        </Grid.RowDefinitions>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock VerticalAlignment="Center" Text="{StaticResource General_Add}" />
                                                            <controls:IdNameSearchBox
                                                                x:Name="InclusionsIdNameSearchBox"
                                                                Grid.Column="1"
                                                                Margin="8,0,0,0" />
                                                        </Grid>
                                                        <ListView
                                                            Grid.Row="1"
                                                            Margin="0,8,0,0"
                                                            BorderBrush="{ThemeResource GrayBrush}"
                                                            BorderThickness="1"
                                                            ItemsSource="{x:Bind VM.Config.Inclusions, Mode=OneWay}"
                                                            SelectionMode="Single"
                                                            Style="{StaticResource StretchListView}">
                                                            <ListView.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition />
                                                                            <ColumnDefinition Width="Auto" />
                                                                            <ColumnDefinition Width="Auto" />
                                                                        </Grid.ColumnDefinitions>
                                                                        <TextBlock
                                                                            VerticalAlignment="Center"
                                                                            Text="{Binding Name}"
                                                                            TextTrimming="CharacterEllipsis"
                                                                            ToolTipService.ToolTip="{Binding Id}" />
                                                                        <TextBlock
                                                                            Grid.Column="1"
                                                                            VerticalAlignment="Center"
                                                                            FontSize="12"
                                                                            Text="{Binding Category, Converter={StaticResource CategoryEnumToStringConverter}}" />
                                                                        <Button
                                                                            Grid.Column="2"
                                                                            Margin="8,0,0,0"
                                                                            Click="DeleteInclusions_Click"
                                                                            Content="×"
                                                                            FontSize="16"
                                                                            Foreground="{ThemeResource RedBrush}"
                                                                            Style="{StaticResource TransparentButton}" />
                                                                    </Grid>
                                                                </DataTemplate>
                                                            </ListView.ItemTemplate>
                                                        </ListView>
                                                    </Grid>
                                                </controls:CardControl.CustomContent>
                                            </controls:CardControl>
                                        </Grid>
                                        <Grid x:Name="NotifySetting" />
                                    </Grid>
                                </controls:CardControl.CustomContent>
                            </controls:CardControl>

                        </Grid>
                    </Grid>
                </Grid>
            </controls:CardControl.CustomContent>
            <controls:CardControl.Fonter>
                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                    <AppBarButton
                        x:Name="Button_Connect"
                        Margin="8,0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Click="Button_Connect_Click"
                        Icon="Play"
                        Label="{StaticResource ZKBHomePage_Connect}" />
                    <AppBarButton
                        x:Name="Button_Disconnect"
                        Margin="8,0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Click="Button_Disconnect_Click"
                        Foreground="{ThemeResource DefaultRed}"
                        Icon="Stop"
                        Label="{StaticResource ZKBHomePage_Disconnect}"
                        Visibility="Collapsed" />
                    <AppBarButton
                        x:Name="Button_Setting"
                        Margin="8,0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Click="Button_Setting_Click"
                        Icon="Setting"
                        Label="{StaticResource General_Setting}" />
                </StackPanel>
            </controls:CardControl.Fonter>
        </controls:CardControl>
    </Grid>
</Page>
