<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="TheGuideToTheNewEden.WinUI.Views.KB.KillStreamPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:TheGuideToTheNewEden.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:kb="using:TheGuideToTheNewEden.WinUI.ViewModels.KB"
    xmlns:local="using:TheGuideToTheNewEden.WinUI.Views.KB"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:winui="using:FluentIcons.WinUI"
    Background="Transparent"
    mc:Ignorable="d">
    <Page.DataContext>
        <kb:ZKBKillStreamViewModel x:Name="VM" />
    </Page.DataContext>
    <Grid CornerRadius="4">
        <controls:CardControl>
            <controls:CardControl.CustomContent>
                <Grid>
                    <Grid x:Name="DisconnectGrid">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Text="{StaticResource ZKBHomePage_DisconnectTip}" />
                    </Grid>
                    <Grid x:Name="ConnectedGrid" Visibility="Collapsed">
                        <controls:CardControl>
                            <controls:CardControl.Header>
                                <SelectorBar SelectionChanged="KBListTab_SelectionChanged">
                                    <SelectorBarItem
                                        IsSelected="True"
                                        Tag="Matched"
                                        Text="{StaticResource ZKBHomePage_MatchedKB}" />
                                    <SelectorBarItem Tag="FilteredOut" Text="{StaticResource ZKBHomePage_FilteredOutKB}" />
                                </SelectorBar>
                            </controls:CardControl.Header>
                            <controls:CardControl.CustomContent>
                                <Grid>
                                    <controls:KBListControl
                                        x:Name="MatchedKBListControl"
                                        IdNameClicked="KBListControl_IdNameClicked"
                                        KBs="{x:Bind VM.KBItemInfos, Mode=OneWay}"
                                        OnItemClicked="KBListControl_OnItemClicked" />
                                    <controls:KBListControl
                                        x:Name="FilteredOutKBListControl"
                                        IdNameClicked="KBListControl_IdNameClicked"
                                        KBs="{x:Bind VM.FilteredOutKBItemInfos, Mode=OneWay}"
                                        OnItemClicked="KBListControl_OnItemClicked" />
                                </Grid>
                            </controls:CardControl.CustomContent>
                        </controls:CardControl>
                    </Grid>
                    <Grid x:Name="SettingGrid" Visibility="Collapsed">
                        <Grid>
                            <controls:CardControl>
                                <controls:CardControl.Header>
                                    <Grid>
                                        <SelectorBar SelectionChanged="Setting_SelectionChanged">
                                            <SelectorBarItem
                                                IsSelected="True"
                                                Tag="General"
                                                Text="{StaticResource SettingPage_General}" />
                                            <SelectorBarItem Tag="Filter" Text="{StaticResource ZKBHomePage_Setting_Filter}" />
                                        </SelectorBar>
                                        <Button
                                            x:Name="CloseSettingButton"
                                            HorizontalAlignment="Right"
                                            Click="CloseSettingButton_Click"
                                            Foreground="Red">
                                            <winui:FluentIcon Icon="Dismiss" />
                                        </Button>
                                    </Grid>
                                </controls:CardControl.Header>
                                <controls:CardControl.CustomContent>
                                    <Grid>
                                        <Grid x:Name="GeneralSetting">
                                            <ScrollViewer>
                                                <StackPanel Spacing="4">
                                                    <StackPanel.ChildrenTransitions>
                                                        <TransitionCollection>
                                                            <EntranceThemeTransition FromVerticalOffset="50" IsStaggeringEnabled="True" />
                                                        </TransitionCollection>
                                                    </StackPanel.ChildrenTransitions>
                                                    <controls:ExpandableSettingControl Title="{StaticResource ZKBSettingPage_AutoConnect}" Description="{StaticResource ZKBSettingPage_AutoConnect_Desc}">
                                                        <ToggleSwitch IsOn="{x:Bind VM.Config.AutoConnect, Mode=TwoWay}" />
                                                    </controls:ExpandableSettingControl>
                                                    <controls:ExpandableSettingControl Title="{StaticResource ZKBSettingPage_Notify}" Description="{StaticResource ZKBSettingPage_Notify_Desc}">
                                                        <ToggleSwitch IsOn="{x:Bind VM.Config.Notify, Mode=TwoWay}" />
                                                    </controls:ExpandableSettingControl>
                                                    <controls:ExpandableSettingControl Title="{StaticResource ZKBSettingPage_MinNotifyValue}" Description="{StaticResource ZKBSettingPage_MinNotifyValue_Desc}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <NumberBox
                                                                Width="128"
                                                                Minimum="0"
                                                                Value="{x:Bind VM.Config.MinNotifyValue, Mode=TwoWay}" />
                                                            <TextBlock
                                                                Margin="4,0,0,0"
                                                                VerticalAlignment="Center"
                                                                Text="ISK" />
                                                        </StackPanel>
                                                    </controls:ExpandableSettingControl>
                                                    <controls:ExpandableSettingControl Title="{StaticResource ZKBSettingPage_MaxKBItems}" Description="{StaticResource ZKBSettingPage_MaxKBItems_Desc}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <NumberBox
                                                                Width="128"
                                                                Minimum="10"
                                                                Value="{x:Bind VM.Config.MaxKBItems, Mode=TwoWay}" />
                                                        </StackPanel>
                                                    </controls:ExpandableSettingControl>
                                                    <controls:ExpandableSettingControl Title="{StaticResource ZKBSettingPage_SortWay}">
                                                        <ComboBox MinWidth="128" SelectedIndex="{x:Bind VM.Config.SortWay, Mode=TwoWay}">
                                                            <ComboBoxItem Content="{StaticResource ZKBSettingPage_SortWay_UploadTime}" />
                                                            <ComboBoxItem Content="{StaticResource ZKBSettingPage_SortWay_CreateTime}" />
                                                        </ComboBox>
                                                    </controls:ExpandableSettingControl>
                                                </StackPanel>
                                            </ScrollViewer>
                                        </Grid>
                                        <Grid x:Name="FilterSetting">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="8" />
                                                <RowDefinition />
                                            </Grid.RowDefinitions>
                                            <SelectorBar SelectionChanged="FilterGroup_SelectionChanged">
                                                <SelectorBarItem
                                                    IsSelected="True"
                                                    Tag="Common"
                                                    Text="{StaticResource ZKBHomePage_Setting_Filter_Global}" />
                                                <SelectorBarItem Tag="Victim" Text="{StaticResource ZKBHomePage_Setting_Filter_Victim}" />
                                                <SelectorBarItem Tag="Attacker" Text="{StaticResource ZKBHomePage_Setting_Filter_Attacker}" />
                                            </SelectorBar>
                                            <Grid Grid.Row="2">
                                                <Grid x:Name="CommonFilterPanel">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition />
                                                        </Grid.RowDefinitions>
                                                        <StackPanel Margin="12,0,0,8" Orientation="Horizontal">
                                                            <winui:FluentIcon
