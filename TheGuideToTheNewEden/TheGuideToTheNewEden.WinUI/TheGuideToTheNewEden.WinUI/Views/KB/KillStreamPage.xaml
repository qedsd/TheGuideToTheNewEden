                                                                Icon="Info"
                                                                IconSize="Size24" />
                                                            <TextBlock
                                                                Margin="4,0,0,0"
                                                                HorizontalAlignment="Left"
                                                                VerticalAlignment="Center"
                                                                Foreground="{ThemeResource SecondaryForegroundBrush}"
                                                                Text="{StaticResource ZKBHomePage_Setting_Filter_Global_Tip}" />
                                                        </StackPanel>
                                                        <Grid Grid.Row="1">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition />
                                                                <ColumnDefinition Width="8" />
                                                                <ColumnDefinition />
                                                            </Grid.ColumnDefinitions>
