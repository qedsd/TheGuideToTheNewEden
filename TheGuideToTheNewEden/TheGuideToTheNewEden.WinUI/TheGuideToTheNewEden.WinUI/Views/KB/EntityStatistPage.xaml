<Page
    x:Class="TheGuideToTheNewEden.WinUI.Views.KB.EntityStatistPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:controls2="using:TheGuideToTheNewEden.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:kb="using:TheGuideToTheNewEden.WinUI.ViewModels.KB"
    xmlns:local="using:TheGuideToTheNewEden.WinUI.Views.KB"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="Transparent"
    mc:Ignorable="d">
    <Page.DataContext>
        <kb:EntityStatistViewModel x:Name="VM" />
    </Page.DataContext>
    <Page.Resources>
        <Style x:Key="StackPanel_ListInfo" TargetType="StackPanel">
            <Setter Property="Margin" Value="0,4" />
            <Setter Property="Orientation" Value="Horizontal" />
        </Style>
        <Style x:Key="TextBlock_ListInfoNmae" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,4" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontWeight" Value="Light" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Width" Value="80" />
        </Style>
        <Style x:Key="TextBlock_Split" TargetType="TextBlock">
            <Setter Property="Margin" Value="2,0,8,0" />
            <Setter Property="Text" Value=":" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="TextBlock_Value" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Page.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <ScrollView Padding="0,12,8,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid Style="{StaticResource InfoCardGrid}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid>
                            <controls:ImageEx
                                Name="Image_Avatar"
                                Width="100"
                                Height="100"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Top"
                                CornerRadius="999"
                                Source="{x:Bind VM.Avatar, Mode=OneWay}"
                                Stretch="Fill"
                                Visibility="{x:Bind VM.Avatar, Mode=OneWay, Converter={StaticResource NullToCollapsedConverter}}" />
                        </Grid>
                        <Grid Grid.Row="1" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                x:Name="CharacterNameTextBlock"
                                FontSize="18"
                                FontWeight="Bold"
                                Text="{x:Bind VM.BaseInfo.Name.Name, Mode=OneWay}"
                                TextWrapping="Wrap" />
                            <Button
                                Grid.Column="1"
                                Margin="4,0,0,0"
                                VerticalAlignment="Center"
                                Command="{x:Bind VM.OpenInBrowerCommand}"
                                Style="{StaticResource LinkButton}"
                                ToolTipService.ToolTip="{StaticResource KBListControl_OpenBrowser}">
                                <Button.Content>
                                    <TextBlock
                                        FontFamily="{StaticResource SymbolThemeFontFamily}"
                                        FontSize="12"
                                        Text="&#xE774;" />
                                </Button.Content>
                            </Button>
                        </Grid>
                        <StackPanel Grid.Row="2" Margin="0,8,0,0">
                            <!--  Corp  -->
                            <StackPanel Style="{StaticResource StackPanel_ListInfo}" Visibility="{x:Bind VM.BaseInfo.CorpName, Mode=OneWay, Converter={StaticResource NullToCollapsedConverter}}">
                                <TextBlock Style="{StaticResource TextBlock_ListInfoNmae}" Text="{StaticResource EntityStatistPage_Corporation}" />
                                <Button
                                    x:Name="Button_Corp"
                                    Click="Button_Corp_Click"
                                    Style="{StaticResource LinkButton}"
                                    Tag="{x:Bind VM.BaseInfo.CorpName, Mode=OneWay}">
                                    <TextBlock Text="{x:Bind VM.BaseInfo.CorpName.Name, Mode=OneWay}" TextWrapping="Wrap" />
                                </Button>
                            </StackPanel>
                            <!--  Alliance  -->
                            <StackPanel Style="{StaticResource StackPanel_ListInfo}" Visibility="{x:Bind VM.BaseInfo.AllianceName, Mode=OneWay, Converter={StaticResource NullToCollapsedConverter}}">
                                <TextBlock Style="{StaticResource TextBlock_ListInfoNmae}" Text="{StaticResource EntityStatistPage_Alliance}" />
                                <Button
                                    x:Name="Button_Alliance"
                                    Click="Button_Alliance_Click"
                                    Style="{StaticResource LinkButton}"
                                    Tag="{x:Bind VM.BaseInfo.AllianceName, Mode=OneWay}">
                                    <TextBlock Text="{x:Bind VM.BaseInfo.AllianceName.Name, Mode=OneWay}" TextWrapping="Wrap" />
                                </Button>
                            </StackPanel>

                            <!--  Executor  -->
                            <StackPanel Style="{StaticResource StackPanel_ListInfo}" Visibility="{x:Bind VM.BaseInfo.ExecutorCorpName, Mode=OneWay, Converter={StaticResource NullToCollapsedConverter}}">
                                <TextBlock Style="{StaticResource TextBlock_ListInfoNmae}" Text="{StaticResource EntityStatistPage_Executor}" />
                                <Button
                                    x:Name="Button_Executor"
                                    Click="Button_Corp_Click"
                                    Style="{StaticResource LinkButton}"
                                    Tag="{x:Bind VM.BaseInfo.ExecutorCorpName, Mode=OneWay}">
                                    <TextBlock Text="{x:Bind VM.BaseInfo.ExecutorCorpName.Name, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                </Button>
                            </StackPanel>
                            <!--  System  -->
                            <StackPanel
                                x:Name="StackPanel_System"
                                Style="{StaticResource StackPanel_ListInfo}"
                                Visibility="{x:Bind VM.BaseInfo.SystemName, Mode=OneWay, Converter={StaticResource NullToCollapsedConverter}}">
                                <TextBlock Style="{StaticResource TextBlock_ListInfoNmae}" Text="{StaticResource EntityStatistPage_System}" />
                                <Button
                                    x:Name="Button_System"
                                    Click="Button_System_Click"
                                    Content="{x:Bind VM.BaseInfo.SystemName.Name, Mode=OneWay}"
                                    Style="{StaticResource LinkButton}"
                                    Tag="{x:Bind VM.BaseInfo.SystemName, Mode=OneWay}" />
                            </StackPanel>
                            <!--  Constellation  -->
                            <StackPanel
                                x:Name="StackPanel_Constellation"
                                Style="{StaticResource StackPanel_ListInfo}"
                                Visibility="{x:Bind VM.BaseInfo.ConstellationName, Mode=OneWay, Converter={StaticResource NullToCollapsedConverter}}">
                                <TextBlock Style="{StaticResource TextBlock_ListInfoNmae}" Text="{StaticResource EntityStatistPage_Constellation}" />
                                <Button
                                    x:Name="Button_Constellation"
                                    Click="Button_Constellation_Click"
                                    Content="{x:Bind VM.BaseInfo.ConstellationName.Name, Mode=OneWay}"
                                    Style="{StaticResource LinkButton}"
                                    Tag="{x:Bind VM.BaseInfo.ConstellationName, Mode=OneWay}" />
                            </StackPanel>
                            <!--  Region  -->
                            <StackPanel
                                x:Name="StackPanel_Region"
                                Style="{StaticResource StackPanel_ListInfo}"
                                Visibility="{x:Bind VM.BaseInfo.RegionName, Mode=OneWay, Converter={StaticResource NullToCollapsedConverter}}">
                                <TextBlock Style="{StaticResource TextBlock_ListInfoNmae}" Text="{StaticResource EntityStatistPage_Region}" />
                                <Button
                                    x:Name="Button_Region"
                                    Click="Button_Region_Click"
                                    Content="{x:Bind VM.BaseInfo.RegionName.Name, Mode=OneWay}"
                                    Style="{StaticResource LinkButton}"
                                    Tag="{x:Bind VM.BaseInfo.RegionName, Mode=OneWay}" />
                            </StackPanel>
                            <!--  Ship  -->
                            <StackPanel
                                x:Name="StackPanel_Ship"
                                Style="{StaticResource StackPanel_ListInfo}"
                                Visibility="{x:Bind VM.BaseInfo.ShipName, Mode=OneWay, Converter={StaticResource NullToCollapsedConverter}}">
                                <TextBlock Style="{StaticResource TextBlock_ListInfoNmae}" Text="{StaticResource EntityStatistPage_Ship}" />
                                <Button
                                    x:Name="Button_Ship"
                                    Click="Button_Ship_Click"
                                    Content="{x:Bind VM.BaseInfo.ShipName.Name, Mode=OneWay}"
                                    Style="{StaticResource LinkButton}"
                                    Tag="{x:Bind VM.BaseInfo.ShipName, Mode=OneWay}" />
                            </StackPanel>
                            <!--  Class  -->
                            <StackPanel
                                x:Name="StackPanel_Class"
                                Style="{StaticResource StackPanel_ListInfo}"
                                Visibility="{x:Bind VM.BaseInfo.ClassName, Mode=OneWay, Converter={StaticResource NullToCollapsedConverter}}">
                                <TextBlock Style="{StaticResource TextBlock_ListInfoNmae}" Text="{StaticResource EntityStatistPage_Class}" />
                                <Button
                                    x:Name="Button_Class"
                                    Click="Button_Class_Click"
                                    Content="{x:Bind VM.BaseInfo.ClassName.Name, Mode=OneWay}"
                                    Style="{StaticResource LinkButton}"
                                    Tag="{x:Bind VM.BaseInfo.ClassName, Mode=OneWay}" />
                            </StackPanel>
                            <!--  Sec  -->
                            <StackPanel
                                x:Name="StackPanel_Sec"
                                Style="{StaticResource StackPanel_ListInfo}"
                                Visibility="{x:Bind VM.BaseInfo.Sec, Mode=OneWay, Converter={StaticResource NullToCollapsedConverter}}">
                                <TextBlock Style="{StaticResource TextBlock_ListInfoNmae}" Text="{StaticResource EntityStatistPage_Sec}" />
                                <TextBlock
                                    x:Name="TextBlock_Sec"
                                    Style="{StaticResource TextBlock_Value}"
                                    Text="{x:Bind VM.BaseInfo.Sec, Mode=OneWay}" />
                            </StackPanel>
                            <!--  Members  -->
                            <StackPanel
                                x:Name="StackPanel_Members"
                                Style="{StaticResource StackPanel_ListInfo}"
                                Visibility="{x:Bind VM.BaseInfo.Members, Mode=OneWay, Converter={StaticResource NullToCollapsedConverter}}">
                                <TextBlock Style="{StaticResource TextBlock_ListInfoNmae}" Text="{StaticResource EntityStatistPage_Members}" />
                                <TextBlock
                                    x:Name="TextBlock_Members"
                                    Style="{StaticResource TextBlock_Value}"
                                    Text="{x:Bind VM.BaseInfo.Members, Mode=OneWay, Converter={StaticResource StringFormatConverter}, ConverterParameter={}{0:N0}}" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Grid>
                <Grid Grid.Row="1" Style="{StaticResource InfoCardGrid}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="28" />
                            <RowDefinition Height="42" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            VerticalAlignment="Center"
                            FontWeight="Thin"
                            Text="{StaticResource EntityStatistPage_DangerRatio}" />
                        <controls2:ProgressBar
                            Grid.Column="1"
                            Margin="12,0,8,0"
                            VerticalAlignment="Center"
                            BarHeight="2"
                            BgColor="{ThemeResource DefaultGreen}"
                            Maximum="100"
                            Minimum="0"
                            ValueColor="{ThemeResource DefaultRed}"
                            Value="{x:Bind VM.Statistic.DangerRatio, Mode=OneWay}" />
                        <TextBlock
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            Text="{x:Bind VM.Statistic.DangerRatio, Mode=OneWay}" />
                        <TextBlock
                            Grid.Column="3"
                            VerticalAlignment="Center"
                            Text="%" />

                        <TextBlock
                            Grid.Row="1"
                            VerticalAlignment="Center"
                            FontWeight="Thin"
                            Text="{StaticResource EntityStatistPage_GangRatio}" />
                        <controls2:ProgressBar
                            Grid.Row="1"
                            Grid.Column="1"
                            Margin="12,0,8,0"
                            VerticalAlignment="Center"
                            BarHeight="2"
                            BgColor="{ThemeResource DefaultGreen}"
                            Maximum="100"
                            Minimum="0"
                            ValueColor="{ThemeResource DefaultRed}"
                            Value="{x:Bind VM.Statistic.GangRatio, Mode=OneWay}" />
                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            Text="{x:Bind VM.Statistic.GangRatio, Mode=OneWay}" />
                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="3"
                            VerticalAlignment="Center"
                            Text="%" />
                    </Grid>
                    <Grid Grid.Row="1" Margin="-16,16,-16,0">
                        <Grid.Resources>
                            <Style x:Key="ItemNameTextBlock" TargetType="TextBlock">
                                <Setter Property="FontSize" Value="12" />
                                <Setter Property="FontWeight" Value="Thin" />
                                <Setter Property="HorizontalAlignment" Value="Center" />
                            </Style>
                            <Style x:Key="ItemValueTextBlock" TargetType="TextBlock">
                                <Setter Property="FontSize" Value="18" />
                                <Setter Property="HorizontalAlignment" Value="Center" />
                            </Style>
                        </Grid.Resources>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="20" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="24" />
                            <RowDefinition Height="20" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="24" />
                            <RowDefinition Height="20" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Style="{StaticResource ItemNameTextBlock}" Text="{StaticResource StatistMonthPage_ItemDestroyed}" />
                        <TextBlock
                            Grid.Column="1"
                            Style="{StaticResource ItemNameTextBlock}"
                            Text="{StaticResource StatistMonthPage_IskDestroyed}" />
                        <TextBlock
                            Grid.Column="2"
                            Style="{StaticResource ItemNameTextBlock}"
                            Text="{StaticResource StatistMonthPage_PointsDestroyed}" />

                        <TextBlock
                            Grid.Row="3"
                            Grid.Column="0"
                            Style="{StaticResource ItemNameTextBlock}"
                            Text="{StaticResource StatistMonthPage_ItemLost}" />
                        <TextBlock
                            Grid.Row="3"
                            Grid.Column="1"
                            Style="{StaticResource ItemNameTextBlock}"
                            Text="{StaticResource StatistMonthPage_IskLost}" />
                        <TextBlock
                            Grid.Row="3"
                            Grid.Column="2"
                            Style="{StaticResource ItemNameTextBlock}"
                            Text="{StaticResource StatistMonthPage_PointsLost}" />

                        <Grid Grid.Row="6" Grid.ColumnSpan="3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                Grid.Column="0"
                                Style="{StaticResource ItemNameTextBlock}"
                                Text="{StaticResource StatistMonthPage_SoloDestroyed}" />
                            <TextBlock
                                Grid.Column="1"
                                Style="{StaticResource ItemNameTextBlock}"
                                Text="{StaticResource StatistMonthPage_SoloLost}" />
                        </Grid>

                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="0"
                            Foreground="{ThemeResource DefaultGreen}"
                            Style="{StaticResource ItemValueTextBlock}"
                            Text="{x:Bind VM.Statistic.ItemDestroyed, Mode=OneWay}" />
                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="1"
                            Foreground="{ThemeResource DefaultGreen}"
                            Style="{StaticResource ItemValueTextBlock}"
                            Text="{x:Bind VM.Statistic.ISKDestroyed, Mode=OneWay, Converter={StaticResource ISKNormalizeConverter}}" />
                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="2"
                            Foreground="{ThemeResource DefaultGreen}"
                            Style="{StaticResource ItemValueTextBlock}"
                            Text="{x:Bind VM.Statistic.PointsDestroyed, Mode=OneWay}" />

                        <TextBlock
                            Grid.Row="4"
                            Grid.Column="0"
                            Foreground="{ThemeResource DefaultRed}"
                            Style="{StaticResource ItemValueTextBlock}"
                            Text="{x:Bind VM.Statistic.ItemLost, Mode=OneWay}" />
                        <TextBlock
                            Grid.Row="4"
                            Grid.Column="1"
                            Foreground="{ThemeResource DefaultRed}"
                            Style="{StaticResource ItemValueTextBlock}"
                            Text="{x:Bind VM.Statistic.ISKLost, Mode=OneWay, Converter={StaticResource ISKNormalizeConverter}}" />
                        <TextBlock
                            Grid.Row="4"
                            Grid.Column="2"
                            Foreground="{ThemeResource DefaultRed}"
                            Style="{StaticResource ItemValueTextBlock}"
                            Text="{x:Bind VM.Statistic.PointsLost, Mode=OneWay, Converter={StaticResource ISKNormalizeConverter}}" />

                        <Grid Grid.Row="7" Grid.ColumnSpan="3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                Grid.Column="0"
                                Foreground="{ThemeResource DefaultGreen}"
                                Style="{StaticResource ItemValueTextBlock}"
                                Text="{x:Bind VM.Statistic.SoloKills, Mode=OneWay, Converter={StaticResource ISKNormalizeConverter}}" />
                            <TextBlock
                                Grid.Column="1"
                                Foreground="{ThemeResource DefaultRed}"
                                Style="{StaticResource ItemValueTextBlock}"
                                Text="{x:Bind VM.Statistic.SoloLosses, Mode=OneWay, Converter={StaticResource ISKNormalizeConverter}}" />
                        </Grid>
                    </Grid>
                </Grid>
            </Grid>
        </ScrollView>
        <TabView
            x:Name="TabView_Statist"
            Grid.Column="1"
            VerticalAlignment="Stretch"
            IsAddTabButtonVisible="False"
            TabWidthMode="Equal">
            <TabViewItem
                x:Name="TabViewItem_List"
                Header="{StaticResource EntityStatistPage_KBList}"
                IsClosable="False" />
            <TabViewItem
                x:Name="TabViewItem_TopValue"
                Header="{StaticResource EntityStatistPage_TopValue}"
                IsClosable="False" />
            <TabViewItem
                x:Name="TabViewItem_TopAllTime"
                Header="{StaticResource EntityStatistPage_TopStatist}"
                IsClosable="False" />
            <TabViewItem
                x:Name="TabViewItem_Group"
                Header="{StaticResource EntityStatistPage_GroupSummary}"
                IsClosable="False" />
            <TabViewItem
                x:Name="TabViewItem_Month"
                Header="{StaticResource EntityStatistPage_MonthSummary}"
                IsClosable="False" />
            <TabViewItem
                x:Name="TabViewItem_Supper"
                Header="{StaticResource EntityStatistPage_SupperSummary}"
                IsClosable="False" />
        </TabView>
    </Grid>
</Page>
