<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="TheGuideToTheNewEden.WinUI.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:TheGuideToTheNewEden.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:TheGuideToTheNewEden.WinUI.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="Transparent"
    mc:Ignorable="d">

    <Grid Margin="0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <!--  导航  -->
        <Grid x:Name="NavPanel" Margin="8,16,8,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="50" />
                <RowDefinition />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <!--  标题  -->
            <StackPanel
                Margin="0,10,0,0"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Orientation="Horizontal">
                <Image Width="16" Source="/Resources/Images/logo.svg" />
                <TextBlock
                    Margin="10,0,0,0"
                    VerticalAlignment="Center"
                    FontFamily="Calibri "
                    FontSize="16"
                    Text="{StaticResource AppDisplayName}" />
            </StackPanel>
            <!--  菜单  -->
            <ListView
                x:Name="MenuList"
                Grid.Row="1"
                Margin="0,0"
                Background="Transparent"
                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                ScrollViewer.VerticalScrollBarVisibility="Hidden"
                SelectedIndex="0"
                SelectionChanged="MenuList_SelectionChanged"
                SelectionMode="Single">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border x:Name="border">
                            <TextBlock Margin="8,0" Text="{Binding Title, Mode=OneWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DynamicResourceFromBindingConverter}}" />
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
            <!--  Footer  -->
            <StackPanel
                Grid.Row="2"
                Margin="0,16,0,8"
                HorizontalAlignment="Center"
                Orientation="Horizontal">
                <StackPanel.Resources>
                    <Style TargetType="TextBlock">
                        <Setter Property="FontSize" Value="11" />
                        <Setter Property="VerticalAlignment" Value="Center" />
                        <Setter Property="Foreground" Value="{ThemeResource SecondaryForegroundBrush}" />
                    </Style>
                </StackPanel.Resources>
                <Button Padding="6,6" Style="{ThemeResource TransparentButton}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="v" />
                        <TextBlock x:Name="VersionTextBlock" Text="3.0.0.0" />
                    </StackPanel>
                </Button>
                <Button Padding="6,6" Style="{ThemeResource TransparentButton}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="by " />
                        <TextBlock Text="QEDSD" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
        <!--  内容  -->
        <Border
            Grid.Column="1"
            Padding="0,4,0,0"
            Background="{ThemeResource DefaultBackgroudBrush}"
            CornerRadius="0">
            <Grid>
                <Frame x:Name="ContentFrame" />
                <controls:LoadingControl
                    x:Name="Loading"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    IsLoading="True" />
                <controls:InfoBarControl
                    x:Name="InfoBar"
                    Margin="0,0,0,16"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Visibility="Collapsed" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
