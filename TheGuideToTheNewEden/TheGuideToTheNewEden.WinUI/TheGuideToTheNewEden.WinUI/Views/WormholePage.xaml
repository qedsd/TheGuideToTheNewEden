<Page
    x:Class="TheGuideToTheNewEden.WinUI.Views.WormholePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:chart="using:Syncfusion.UI.Xaml.Charts"
    xmlns:controls="using:TheGuideToTheNewEden.WinUI.Controls"
    xmlns:converters="using:TheGuideToTheNewEden.WinUI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dataGrid="using:Syncfusion.UI.Xaml.DataGrid"
    xmlns:dbmodels="using:TheGuideToTheNewEden.Core.DBModels"
    xmlns:interactivity="using:Microsoft.Xaml.Interactivity"
    xmlns:local="using:TheGuideToTheNewEden.WinUI.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="using:TheGuideToTheNewEden.WinUI.ViewModels"
    xmlns:winui="using:FluentIcons.WinUI"
    Background="Transparent"
    NavigationCacheMode="Required"
    mc:Ignorable="d">
    <Page.DataContext>
        <viewmodels:WormholeViewModel x:Name="VM" />
    </Page.DataContext>
    <Page.Resources>
        <converters:DayOfWeekToStringConverter x:Key="DayOfWeekToStringConverter" />
        <DataTemplate x:Key="ToolTipTemplate">
            <StackPanel Orientation="Horizontal">
                <TextBlock Foreground="{ThemeResource ThemeMainColor}" Text="{Binding Item.ToolTip}" />
            </StackPanel>
        </DataTemplate>
    </Page.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <controls:CardControl>
            <controls:CardControl.Header>
                <AutoSuggestBox
                    Name="Search_AutoSuggestBox"
                    HorizontalAlignment="Stretch"
                    DisplayMemberPath="Name"
                    ItemsSource="{x:Bind VM.SearchWormholes, Mode=OneWay}"
                    PlaceholderText="{StaticResource WormholePage_Search}"
                    QueryIcon="Find"
                    SuggestionChosen="AutoSuggestBox_SuggestionChosen"
                    Text="{x:Bind VM.SearchText, Mode=TwoWay}"
                    TextMemberPath="Name" />
            </controls:CardControl.Header>
            <controls:CardControl.CustomContent>
                <Grid Margin="16,4" Visibility="{x:Bind VM.WormholeDetail, Mode=OneWay, Converter={StaticResource NullToCollapsedConverter}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition />
                    </Grid.RowDefinitions>
                    <TextBlock
                        FontSize="32"
                        Foreground="{ThemeResource SystemAccentColor}"
                        IsTextSelectionEnabled="True"
                        Text="{x:Bind VM.WormholeDetail.Name, Mode=OneWay}" />
                    <Grid Grid.Row="1" Margin="0,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,12,0"
                                Foreground="{ThemeResource SecondaryForegroundBrush}"
                                Text="{StaticResource WormholePage_Class}" />
                            <TextBlock IsTextSelectionEnabled="True" Text="{x:Bind VM.WormholeDetail.ClassName, Mode=OneWay}" />
                        </StackPanel>
                    </Grid>
                    <Grid Grid.Row="2" Margin="0,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,12,0"
                                Foreground="{ThemeResource SecondaryForegroundBrush}"
                                Text="{StaticResource WormholePage_Phenomena}" />
                            <TextBlock IsTextSelectionEnabled="True" Text="{x:Bind VM.WormholeDetail.PhenomenaName, Mode=OneWay}" />
                        </StackPanel>
                    </Grid>
                    <Grid Grid.Row="3" Visibility="{x:Bind VM.WormholeDetail.StaticsPortals, Mode=OneWay, Converter={StaticResource NullToCollapsedConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            Margin="0,12,12,0"
                            Foreground="{ThemeResource SecondaryForegroundBrush}"
                            Text="{StaticResource WormholePage_Static}" />
                        <GridView
                            Grid.Column="1"
                            ItemsSource="{x:Bind VM.WormholeDetail.StaticsPortals, Mode=OneWay}"
                            SelectionMode="None">
                            <GridView.ItemContainerStyle>
                                <Style TargetType="GridViewItem">
                                    <Setter Property="Margin" Value="0,0,4,-8" />
                                    <Setter Property="Padding" Value="0" />
                                </Style>
                            </GridView.ItemContainerStyle>
                            <GridView.ItemTemplate>
                                <DataTemplate>
                                    <Button
                                        Width="60"
                                        Click="PortalButton_Click"
                                        Content="{Binding Name}" />
                                </DataTemplate>
                            </GridView.ItemTemplate>
                        </GridView>
                    </Grid>
                    <Grid Grid.Row="4" Visibility="{x:Bind VM.WormholeDetail.WanderingPortals, Mode=OneWay, Converter={StaticResource NullToCollapsedConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            Margin="0,12,12,0"
                            Foreground="{ThemeResource SecondaryForegroundBrush}"
                            Text="{StaticResource WormholePage_Wandering}" />
                        <GridView
                            Grid.Column="1"
                            ItemsSource="{x:Bind VM.WormholeDetail.WanderingPortals, Mode=OneWay}"
                            SelectionMode="None">
                            <GridView.ItemContainerStyle>
                                <Style TargetType="GridViewItem">
                                    <Setter Property="Margin" Value="0,0,4,-8" />
                                    <Setter Property="Padding" Value="0" />
                                </Style>
                            </GridView.ItemContainerStyle>
                            <GridView.ItemTemplate>
                                <DataTemplate>
                                    <Button
                                        Width="60"
                                        Click="PortalButton_Click"
                                        Content="{Binding Name}" />
                                </DataTemplate>
                            </GridView.ItemTemplate>
                        </GridView>
                    </Grid>
                    <Grid Grid.Row="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            Margin="0,12,12,0"
                            Foreground="{ThemeResource SecondaryForegroundBrush}"
                            Text="{StaticResource WormholePage_Links}" />
                        <GridView
                            Grid.Column="1"
                            ItemsSource="{x:Bind VM.Links}"
                            SelectionMode="None">
                            <GridView.ItemContainerStyle>
                                <Style TargetType="GridViewItem">
                                    <Setter Property="Margin" Value="0,0,4,-8" />
                                    <Setter Property="Padding" Value="0" />
                                </Style>
                            </GridView.ItemContainerStyle>
                            <GridView.ItemTemplate>
                                <DataTemplate>
                                    <Button
                                        Width="90"
                                        Click="LinkButton_Click"
                                        Content="{Binding}" />
                                </DataTemplate>
                            </GridView.ItemTemplate>
                        </GridView>
                    </Grid>
                    <TabView Grid.Row="6" IsAddTabButtonVisible="False">
                        <TabView.Resources>
                            <DataTemplate x:Key="MapDenormalizeDetail">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding ItemName}" ToolTipService.ToolTip="{Binding ItemID}" />
                                    <TextBlock Grid.Column="1" Text="{Binding Type.TypeName}" />
                                </Grid>
                            </DataTemplate>
                        </TabView.Resources>
                        <TabView.TabItems>
                            <TabViewItem Header="{StaticResource WormholePage_Planet}" IsClosable="False">
                                <ListView ItemsSource="{x:Bind VM.WormholeDetail.Planet, Mode=OneWay}" Style="{StaticResource StretchListView}">
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="dbmodels:MapDenormalizeDetail">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding ItemName}" ToolTipService.ToolTip="{Binding ItemID}" />
                                                <TextBlock Grid.Column="1" Text="{Binding Type.TypeName}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </TabViewItem>
                            <TabViewItem Header="{StaticResource WormholePage_Moon}" IsClosable="False">
                                <ListView
                                    ItemTemplate="{StaticResource MapDenormalizeDetail}"
                                    ItemsSource="{x:Bind VM.WormholeDetail.Moon, Mode=OneWay}"
                                    Style="{StaticResource StretchListView}" />
                            </TabViewItem>
                            <TabViewItem Header="{StaticResource WormholePage_Other}" IsClosable="False">
                                <ListView
                                    ItemTemplate="{StaticResource MapDenormalizeDetail}"
                                    ItemsSource="{x:Bind VM.WormholeDetail.Other, Mode=OneWay}"
                                    Style="{StaticResource StretchListView}" />
                            </TabViewItem>
                        </TabView.TabItems>
                    </TabView>
                </Grid>
            </controls:CardControl.CustomContent>
        </controls:CardControl>
        <controls:CardControl Grid.Column="1" Visibility="{x:Bind VM.WormholeDetail, Mode=OneWay, Converter={StaticResource NullToCollapsedConverter}}">
            <controls:CardControl.Header>
                <Grid>
                    <Grid.Resources>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center" />
                        </Style>
                    </Grid.Resources>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{StaticResource WormholePage_ZKB}" />
                        <TextBlock Text=" (" />
                        <TextBlock Text="{x:Bind VM.KMDataFrom, Mode=OneWay}" />
                        <TextBlock Text=")" />
                    </StackPanel>

                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                        <Button
                            Command="{x:Bind VM.ZKBDetailCommand}"
                            Style="{StaticResource TransparentButton}"
                            ToolTipService.ToolTip="{StaticResource WormholePage_ZKB_Detail}">
                            <winui:FluentIcon Icon="ScanObject" />
                        </Button>
                        <Button Command="{x:Bind VM.RefreshZKBDataCommand}" Style="{StaticResource TransparentButton}">
                            <winui:FluentIcon Icon="ArrowSync" ToolTipService.ToolTip="{StaticResource General_Refresh}" />
                        </Button>
                    </StackPanel>
                </Grid>
            </controls:CardControl.Header>
            <controls:CardControl.CustomContent>
                <Grid Padding="8">
                    <Grid Visibility="{x:Bind VM.LoadingZKB, Mode=OneWay, Converter={StaticResource FalseToVisibleConverter}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <Grid Visibility="{x:Bind VM.CorpStatistics, Mode=OneWay, Converter={StaticResource NullToCollapsedConverter}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock
                                Margin="8,0,0,4"
                                Foreground="{ThemeResource SecondaryForegroundBrush}"
                                Text="{StaticResource WormholePage_ZKB_MostActiveCorporations}" />
                            <ListView Grid.Row="1" ItemsSource="{x:Bind VM.CorpStatistics, Mode=OneWay}">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="viewmodels:WormholeFactionStatistic">
                                        <Grid Height="32">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Orientation="Horizontal">
                                                <controls:ImageControl Margin="0,4" Source="{Binding Name.Id, Converter={StaticResource CorpImgConverter}}" />
                                                <Button
                                                    Margin="12,0,0,0"
                                                    VerticalAlignment="Center"
                                                    Click="IdNameButton_Click"
                                                    Content="{Binding Name.Name}"
                                                    Style="{StaticResource TransparentButton}" />
                                            </StackPanel>
                                            <StackPanel
                                                Grid.Column="1"
                                                Margin="4,0"
                                                Orientation="Horizontal">
                                                <TextBlock VerticalAlignment="Center" Text="{Binding KMCount}" />
                                                <TextBlock
                                                    Margin="4,0,0,0"
                                                    VerticalAlignment="Center"
                                                    Text="Kills" />
                                            </StackPanel>
                                            <StackPanel
                                                Grid.Column="2"
                                                Margin="4,0"
                                                Orientation="Horizontal">
                                                <TextBlock VerticalAlignment="Center" Text="{StaticResource WormholePage_ZKB_LastActive}" />
                                                <TextBlock
                                                    Margin="4,0"
                                                    VerticalAlignment="Center"
                                                    Text="{x:Bind LastActiveDay, Converter={StaticResource StringFormatConverter}, ConverterParameter={}{0:N1}}" />
                                                <TextBlock VerticalAlignment="Center" Text="{StaticResource WormholePage_ZKB_DaysAgo}" />
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                        <Grid
                            Grid.Row="1"
                            Margin="0,8,0,0"
                            Visibility="{x:Bind VM.AllianceStatistics, Mode=OneWay, Converter={StaticResource NullToCollapsedConverter}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock
                                Margin="8,0,0,4"
                                Foreground="{ThemeResource SecondaryForegroundBrush}"
                                Text="{StaticResource WormholePage_ZKB_MostActiveAlliances}" />
                            <ListView Grid.Row="1" ItemsSource="{x:Bind VM.AllianceStatistics, Mode=OneWay}">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="viewmodels:WormholeFactionStatistic">
                                        <Grid Height="32">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Orientation="Horizontal">
                                                <controls:ImageControl Margin="0,4" Source="{Binding Name.Id, Converter={StaticResource AllianceImgConverter}}" />
                                                <Button
                                                    Margin="12,0,0,0"
                                                    VerticalAlignment="Center"
                                                    Click="IdNameButton_Click"
                                                    Content="{Binding Name.Name}"
                                                    Style="{StaticResource TransparentButton}" />
                                            </StackPanel>
                                            <StackPanel
                                                Grid.Column="1"
                                                Margin="4,0"
                                                Orientation="Horizontal">
                                                <TextBlock VerticalAlignment="Center" Text="{Binding KMCount}" />
                                                <TextBlock
                                                    Margin="4,0,0,0"
                                                    VerticalAlignment="Center"
                                                    Text="Kills" />
                                            </StackPanel>
                                            <StackPanel
                                                Grid.Column="2"
                                                Margin="4,0"
                                                Orientation="Horizontal">
                                                <TextBlock VerticalAlignment="Center" Text="{StaticResource WormholePage_ZKB_LastActive}" />
                                                <TextBlock
                                                    Margin="4,0"
                                                    VerticalAlignment="Center"
                                                    Text="{x:Bind LastActiveDay, Converter={StaticResource StringFormatConverter}, ConverterParameter={}{0:N1}}" />
                                                <TextBlock VerticalAlignment="Center" Text="{StaticResource WormholePage_ZKB_DaysAgo}" />
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                        <chart:SfCartesianChart Grid.Row="2" Margin="0,8,0,0">
                            <chart:SfCartesianChart.Resources>
                                <Style TargetType="chart:BubbleSeries">
                                    <Setter Property="MinimumRadius" Value="1" />
                                    <Setter Property="MaximumRadius" Value="15" />
                                    <Setter Property="Size" Value="Count" />
                                    <Setter Property="XBindingPath" Value="Day" />
                                    <Setter Property="YBindingPath" Value="Hour" />
                                    <Setter Property="EnableAnimation" Value="True" />
                                    <Setter Property="EnableTooltip" Value="True" />
                                    <Setter Property="TooltipTemplate" Value="{StaticResource ToolTipTemplate}" />
                                </Style>
                            </chart:SfCartesianChart.Resources>
                            <chart:SfCartesianChart.XAxes>
                                <chart:NumericalAxis
                                    EdgeLabelsDrawingMode="Hide"
                                    Interval="1"
                                    Maximum="7"
                                    Minimum="-1"
                                    RangePadding="Additional">
                                    <chart:NumericalAxis.LabelTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Content, Converter={StaticResource DayOfWeekToStringConverter}}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </chart:NumericalAxis.LabelTemplate>
                                </chart:NumericalAxis>
                            </chart:SfCartesianChart.XAxes>

                            <chart:SfCartesianChart.YAxes>
                                <chart:NumericalAxis
                                    EdgeLabelsDrawingMode="Hide"
                                    Header="{StaticResource General_LocalTime}"
                                    Maximum="25"
                                    Minimum="-1"
                                    RangePadding="Additional">
                                    <chart:NumericalAxis.LabelTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Content}" />
                                                <TextBlock Text="h" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </chart:NumericalAxis.LabelTemplate>
                                </chart:NumericalAxis>
                            </chart:SfCartesianChart.YAxes>

                            <chart:BubbleSeries ItemsSource="{x:Bind VM.WormholeActives1, Mode=OneWay}" />
                            <chart:BubbleSeries ItemsSource="{x:Bind VM.WormholeActives2, Mode=OneWay}" />
                            <chart:BubbleSeries ItemsSource="{x:Bind VM.WormholeActives3, Mode=OneWay}" />
                            <chart:BubbleSeries ItemsSource="{x:Bind VM.WormholeActives4, Mode=OneWay}" />
                            <chart:BubbleSeries ItemsSource="{x:Bind VM.WormholeActives5, Mode=OneWay}" />
                            <chart:BubbleSeries ItemsSource="{x:Bind VM.WormholeActives6, Mode=OneWay}" />
                            <chart:BubbleSeries ItemsSource="{x:Bind VM.WormholeActives7, Mode=OneWay}" />
                        </chart:SfCartesianChart>
                    </Grid>

                    <controls:LoadingControl
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        IsLoading="{x:Bind VM.LoadingZKB, Mode=OneWay}"
                        Visibility="{x:Bind VM.LoadingZKB, Mode=OneWay, Converter={StaticResource TrueToVisibleConverter}}" />
                </Grid>
            </controls:CardControl.CustomContent>
        </controls:CardControl>
    </Grid>
</Page>
