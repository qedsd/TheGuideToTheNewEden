<Page
    x:Class="TheGuideToTheNewEden.WinUI.Views.Business.ShoppingCartPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:TheGuideToTheNewEden.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dataGrid="using:Syncfusion.UI.Xaml.DataGrid"
    xmlns:local="using:TheGuideToTheNewEden.WinUI.Views.Business"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:winui="using:FluentIcons.WinUI"
    Background="Transparent"
    mc:Ignorable="d">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <controls:CardControl>
            <controls:CardControl.Header>
                <TextBlock Text="{StaticResource BusinessPage_Statistics}" />
            </controls:CardControl.Header>
            <controls:CardControl.CustomContent>
                <Grid Margin="16,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40" />
                        <RowDefinition Height="40" />
                        <RowDefinition Height="40" />
                        <RowDefinition Height="40" />
                        <RowDefinition Height="40" />
                        <RowDefinition Height="40" />
                        <RowDefinition Height="40" />
                        <RowDefinition Height="40" />
                        <RowDefinition Height="40" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="{StaticResource BusinessPage_ROIPercent}" />
                    <TextBlock x:Name="TextBlock_ROI" Grid.Column="2" />

                    <TextBlock Grid.Row="1" Text="{StaticResource BusinessPage_NetProfit}" />
                    <TextBlock
                        x:Name="TextBlock_NetProfi"
                        Grid.Row="1"
                        Grid.Column="2" />

                    <TextBlock Grid.Row="2" Text="{StaticResource BusinessPage_Principal}" />
                    <TextBlock
                        x:Name="TextBlock_Principal"
                        Grid.Row="2"
                        Grid.Column="2" />

                    <TextBlock Grid.Row="3" Text="{StaticResource BusinessPage_Volume}" />
                    <TextBlock
                        x:Name="TextBlock_Volume"
                        Grid.Row="3"
                        Grid.Column="2" />

                    <TextBlock Grid.Row="4" Text="{StaticResource BusinessPage_IskPerJump}" />
                    <TextBlock
                        x:Name="TextBlock_IskPerJump"
                        Grid.Row="4"
                        Grid.Column="2" />

                    <TextBlock Grid.Row="5" Text="{StaticResource BusinessPage_IskPerVolume}" />
                    <TextBlock
                        x:Name="TextBlock_IskPerVolume"
                        Grid.Row="5"
                        Grid.Column="2" />

                    <TextBlock Grid.Row="6" Text="{StaticResource BusinessPage_TypeVolume}" />
                    <TextBlock
                        x:Name="TextBlock_TypeCount"
                        Grid.Row="6"
                        Grid.Column="2" />
                </Grid>
            </controls:CardControl.CustomContent>
            <controls:CardControl.Fonter>
                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                    <Button
                        Margin="8"
                        HorizontalAlignment="Center"
                        Click="AppBarButton_CopyToGameOrder_Click"
                        Style="{StaticResource TransparentButton}"
                        ToolTipService.ToolTip="{StaticResource BusinessPage_CopyToGameOrder}">
                        <winui:FluentIcon Icon="Copy" IconSize="Resizable" />
                    </Button>
                    <Button
                        Margin="8"
                        HorizontalAlignment="Center"
                        Click="AppBarButton_PasteFromGameOrder_Click"
                        Style="{StaticResource TransparentButton}"
                        ToolTipService.ToolTip="{StaticResource BusinessPage_PasteFromGameOrder}">
                        <winui:FluentIcon Icon="ClipboardPaste" IconSize="Resizable" />
                    </Button>
                    <Button
                        Grid.Row="2"
                        Margin="8"
                        Background="Transparent"
                        Click="AppBarButton_SaveOrder_Click"
                        Style="{StaticResource TransparentButton}"
                        ToolTipService.ToolTip="{StaticResource BusinessPage_SaveOrder}">
                        <winui:FluentIcon Icon="Save" IconSize="Resizable" />
                    </Button>
                </StackPanel>
            </controls:CardControl.Fonter>
        </controls:CardControl>
        <dataGrid:SfDataGrid
            x:Name="ItemsDataGrid"
            Grid.Column="1"
            Margin="0,0,0,0"
            HorizontalAlignment="Stretch"
            AllowDraggingColumns="True"
            AllowEditing="False"
            AllowFiltering="True"
            AllowGrouping="True"
            AllowResizingColumns="True"
            AllowSorting="True"
            AutoGenerateColumns="False"
            Background="{ThemeResource TransparentBackgroudBrush}"
            ColumnWidthMode="Auto"
            DoubleTapped="SfDataGrid_DoubleTapped"
            GridLinesVisibility="None"
            GroupDropAreaText="{StaticResource General_GroupDropAreaText}"
            HeaderLinesVisibility="Both"
            SelectionMode="Extended"
            ShowGroupDropArea="True">
            <dataGrid:SfDataGrid.Columns>
                <dataGrid:GridTextColumn HeaderText="{StaticResource BusinessPage_Type}" MappingName="InvType.TypeName" />
                <dataGrid:GridNumericColumn
                    DisplayNumberFormat="N2"
                    HeaderText="{StaticResource BusinessPage_ROIPercent}"
                    MappingName="ROI" />
                <dataGrid:GridNumericColumn
                    DisplayNumberFormat="N2"
                    HeaderText="{StaticResource BusinessPage_NetProfit}"
                    MappingName="NetProfit" />
                <dataGrid:GridNumericColumn
                    DisplayNumberFormat="N2"
                    HeaderText="{StaticResource BusinessPage_SourceBuyPrice}"
                    MappingName="BuyPrice" />
                <dataGrid:GridNumericColumn
                    DisplayNumberFormat="N2"
                    HeaderText="{StaticResource BusinessPage_DestinationSellPrice}"
                    MappingName="SellPrice" />

                <dataGrid:GridNumericColumn
                    DisplayNumberFormat="N0"
                    HeaderText="{StaticResource General_Quantity}"
                    MappingName="Quantity" />

                <dataGrid:GridNumericColumn
                    DisplayNumberFormat="N2"
                    HeaderText="{StaticResource BusinessPage_Volume}"
                    MappingName="Volume" />


            </dataGrid:SfDataGrid.Columns>
            <dataGrid:SfDataGrid.RecordContextFlyout>
                <MenuFlyout>
                    <MenuFlyoutItem
                        Click="MenuFlyoutItem_Edit_Click"
                        CommandParameter="{Binding}"
                        Text="{StaticResource BusinessPage_Edit}" />
                    <MenuFlyoutItem
                        Click="MenuFlyoutItem_Remove_Click"
                        CommandParameter="{Binding}"
                        Text="{StaticResource General_Remove}" />
                </MenuFlyout>
            </dataGrid:SfDataGrid.RecordContextFlyout>

        </dataGrid:SfDataGrid>
    </Grid>
</Page>
