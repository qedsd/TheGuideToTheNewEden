<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="TheGuideToTheNewEden.WinUI.Views.Home.WalletStatistic"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls1="using:TheGuideToTheNewEden.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:TheGuideToTheNewEden.WinUI.Views.Home"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:winui="using:FluentIcons.WinUI"
    mc:Ignorable="d">
    <UserControl.Resources>
        <DataTemplate x:Key="WalletDataTemplate" x:DataType="local:WalletStatisticModel">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <TextBlock
                    Width="60"
                    FontSize="13"
                    Text="{x:Bind Name}" />
                <TextBlock
                    Grid.Column="1"
                    Width="30"
                    FontSize="13"
                    Text="{x:Bind Percent, Converter={StaticResource StringFormatConverter}, ConverterParameter={}{0:N2}}"
                    TextAlignment="Right" />
                <TextBlock
                    Grid.Column="2"
                    FontSize="13"
                    Text="%" />
                <controls1:ProgressBar
                    Grid.Column="3"
                    Margin="8,0,0,0"
                    VerticalAlignment="Center"
                    BarHeight="2"
                    Maximum="100"
                    Minimum="0"
                    ValueColor="{x:Bind Brush}"
                    Value="{x:Bind Percent}" />
            </Grid>
        </DataTemplate>
        <Style x:Key="WalletListView" TargetType="ListView">
            <Setter Property="Margin" Value="-8,0" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Hidden" />
            <Setter Property="SelectionMode" Value="Single" />
            <Setter Property="ItemTemplate" Value="{StaticResource WalletDataTemplate}" />
        </Style>
    </UserControl.Resources>
    <Grid
        Padding="8,16"
        Background="{ThemeResource TransparentBackgroudBrush}"
        CornerRadius="8">
        <ProgressRing
            x:Name="LoadingUI"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            IsActive="False"
            Visibility="Collapsed" />
        <TextBlock
            x:Name="TipTextBlock"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Visibility="Collapsed" />
        <Grid x:Name="ContentGrid" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition />
            </Grid.RowDefinitions>
            <StackPanel Margin="8,0">
                <TextBlock
                    Margin="0,0,0,4"
                    FontSize="13"
                    Foreground="{ThemeResource SecondaryForegroundBrush}"
                    Text="{StaticResource HomePage_Wallet_Tip}" />
                <StackPanel Orientation="Horizontal">
                    <TextBlock
                        x:Name="WalletSumTextBlock"
                        FontSize="20"
                        IsTextSelectionEnabled="True" />
                </StackPanel>

                <TextBlock
                    x:Name="DiffWalletTextBlock"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    FontSize="13"
                    Foreground="White"
                    IsTextSelectionEnabled="True"
                    Visibility="Collapsed" />
            </StackPanel>
            <Grid Grid.Row="1" Margin="0,16,0,0">
                <Grid.Resources>
                    <Style TargetType="TextBlock">
                        <Setter Property="VerticalAlignment" Value="Center" />
                    </Style>
                </Grid.Resources>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="32" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <StackPanel Margin="8,0,8,4" Orientation="Horizontal">
                    <TextBlock
                        FontSize="13"
                        Foreground="{ThemeResource SecondaryForegroundBrush}"
                        Text="{StaticResource HomePage_Wallet_In}" />
                    <TextBlock
                        x:Name="InWalletTextBlock"
                        Margin="6,0,0,0"
                        FontSize="13"
                        Foreground="{StaticResource DefaultGreen}" />
                </StackPanel>
                <ListView
                    x:Name="WalletListView_In"
                    Grid.Row="1"
                    Style="{StaticResource WalletListView}" />
                <StackPanel
                    Grid.Column="2"
                    Margin="8,0,8,4"
                    Orientation="Horizontal">
                    <TextBlock
                        FontSize="13"
                        Foreground="{ThemeResource SecondaryForegroundBrush}"
                        Text="{StaticResource HomePage_Wallet_Out}" />
                    <TextBlock
                        x:Name="OutWalletTextBlock"
                        Margin="6,0,0,0"
                        FontSize="13"
                        Foreground="{StaticResource DefaultRed}" />
                </StackPanel>
                <ListView
                    x:Name="WalletListView_Out"
                    Grid.Row="1"
                    Grid.Column="2"
                    Style="{StaticResource WalletListView}" />
            </Grid>
        </Grid>
        <Button
            x:Name="LoadDataButton"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Click="LoadDataButton_Click"
            Style="{StaticResource TransparentButton}"
            Visibility="Visible">
            <winui:FluentIcon Icon="ArrowSync" />
        </Button>
    </Grid>
</UserControl>
