<Page
    x:Class="TheGuideToTheNewEden.WinUI.Views.TranslationPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:TheGuideToTheNewEden.WinUI.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="Transparent"
    NavigationCacheMode="Enabled"
    mc:Ignorable="d">

    <Grid Margin="8,16,8,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <AutoSuggestBox
            Name="Search_AutoSuggestBox"
            Width="300"
            Margin="8,0"
            HorizontalAlignment="Left"
            BorderThickness="1"
            DisplayMemberPath="Name"
            QueryIcon="Find"
            SuggestionChosen="AutoSuggestBox_SuggestionChosen"
            TextChanged="AutoSuggestBox_TextChanged" />
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <StackPanel VerticalAlignment="Center">
                <Image x:Name="Image_Type" Width="48" />
                <RichTextBlock
                    Margin="0,8"
                    HorizontalAlignment="Center"
                    HorizontalTextAlignment="Center">
                    <Paragraph>
                        <Run x:Name="Name_EN" FontSize="26" />
                    </Paragraph>
                    <Paragraph>
                        <Run
                            x:Name="Name_Local"
                            FontSize="20"
                            FontWeight="Light" />
                    </Paragraph>
                </RichTextBlock>
            </StackPanel>
            <ScrollViewer Grid.Column="1" Margin="0,8,0,40">
                <RichTextBlock x:Name="RichTextBlock_Desc" VerticalAlignment="Center" />
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
