<Page
    x:Class="TheGuideToTheNewEden.WinUI.Views.TranslationPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:TheGuideToTheNewEden.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:TheGuideToTheNewEden.WinUI.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="using:TheGuideToTheNewEden.WinUI.ViewModels"
    xmlns:winui="using:FluentIcons.WinUI"
    Background="Transparent"
    NavigationCacheMode="Required"
    mc:Ignorable="d">
    <Page.DataContext>
        <viewmodels:TranslationViewModel x:Name="VM" />
    </Page.DataContext>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="340" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <controls:CardControl>
            <controls:CardControl.Header>
                <TextBlock Text="{StaticResource TranslationPage_Input}" />
            </controls:CardControl.Header>
            <controls:CardControl.Content>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition />
                    </Grid.RowDefinitions>
                    <TextBox
                        MinHeight="54"
                        Margin="2"
                        KeyDown="TextBox_KeyDown"
                        PlaceholderText="{StaticResource TranslationPage_Input_Tip}"
                        TextChanged="TextBox_TextChanged"
                        TextWrapping="Wrap" />
                    <ListView
                        Grid.Row="1"
                        ItemsSource="{x:Bind VM.DataBaseSearchItems, Mode=OneWay}"
                        SelectedItem="{x:Bind VM.SelectedDataBaseSearchItem, Mode=TwoWay}"
                        Style="{StaticResource StretchListView}">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="4,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Name}" TextWrapping="Wrap" />
                                    <TextBlock
                                        Grid.Column="1"
                                        Margin="4,0,0,0"
                                        FontSize="12"
                                        Foreground="{ThemeResource SecondaryForegroundBrush}"
                                        Text="{Binding Type}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <TextBlock
                        Grid.Row="1"
                        Margin="32,0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Text="{StaticResource TranslationPage_NoResultTip}"
                        TextWrapping="Wrap"
                        Visibility="{x:Bind VM.ShowEmptyResultTip, Mode=OneWay, Converter={StaticResource TrueToVisibleConverter}}" />
                </Grid>
            </controls:CardControl.Content>
            <controls:CardControl.Fonter>
                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                    <AppBarButton
                        Margin="8,0"
                        HorizontalAlignment="Center"
                        AllowFocusOnInteraction="True"
                        Label="{StaticResource General_Setting}">
                        <AppBarButton.Icon>
                            <winui:FluentIcon Icon="Settings" />
                        </AppBarButton.Icon>
                        <AppBarButton.Flyout>
                            <Flyout>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <ComboBox
                                        Width="100"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Center"
                                        Header="{StaticResource TranslationPage_FromLanguage}"
                                        ItemsSource="{x:Bind VM.Froms}"
                                        SelectedItem="{x:Bind VM.FromLanguage, Mode=TwoWay}" />
                                    <ComboBox
                                        Grid.Row="1"
                                        Width="100"
                                        Margin="0,16,0,0"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Center"
                                        Header="{StaticResource TranslationPage_ToLanguage}"
                                        ItemsSource="{x:Bind VM.Tos}"
                                        SelectedItem="{x:Bind VM.ToLanguage, Mode=TwoWay}" />
                                </Grid>
                            </Flyout>
                        </AppBarButton.Flyout>
                    </AppBarButton>
                    <AppBarButton
                        Margin="8,0"
                        HorizontalAlignment="Center"
                        AllowFocusOnInteraction="True"
                        Command="{x:Bind VM.PopWindowCommand}"
                        Label="{StaticResource TranslationPage_PopWindow}">
                        <AppBarButton.Icon>
                            <winui:FluentIcon Icon="PanelSeparateWindow" />
                        </AppBarButton.Icon>
                    </AppBarButton>
                </StackPanel>
            </controls:CardControl.Fonter>
        </controls:CardControl>
        <controls:CardControl Grid.Column="1">
            <controls:CardControl.Header>
                <TextBlock Text="{StaticResource TranslationPage_Result}" />
            </controls:CardControl.Header>
            <controls:CardControl.Content>
                <ScrollViewer>
                    <Grid Margin="16" Visibility="{x:Bind VM.TranslationResult, Mode=OneWay, Converter={StaticResource NullToCollapsedConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="24" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="24" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="24" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <StackPanel.Resources>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{ThemeResource SecondaryForegroundBrush}" />
                                </Style>
                            </StackPanel.Resources>
                            <TextBlock Text="{StaticResource TranslationPage_Query}" />
                            <StackPanel Orientation="Horizontal" Visibility="{x:Bind VM.TranslationResult.IsFromDataBase, Mode=OneWay, Converter={StaticResource FalseToVisibleConverter}}">
                                <TextBlock Text="[" />
                                <TextBlock Text="{x:Bind VM.TranslationResult.From, Mode=OneWay}" />
                                <TextBlock Text="]" />
                            </StackPanel>
                        </StackPanel>

                        <TextBlock
                            Grid.Column="2"
                            IsTextSelectionEnabled="True"
                            Text="{x:Bind VM.TranslationResult.Query, Mode=OneWay}"
                            TextWrapping="Wrap" />

                        <StackPanel Grid.Row="2" Orientation="Horizontal">
                            <StackPanel.Resources>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{ThemeResource SecondaryForegroundBrush}" />
                                </Style>
                            </StackPanel.Resources>
                            <TextBlock Text="{StaticResource TranslationPage_Translation}" />
                            <StackPanel Orientation="Horizontal" Visibility="{x:Bind VM.TranslationResult.IsFromDataBase, Mode=OneWay, Converter={StaticResource FalseToVisibleConverter}}">
                                <TextBlock Text="[" />
                                <TextBlock Text="{x:Bind VM.TranslationResult.To, Mode=OneWay}" />
                                <TextBlock Text="]" />
                            </StackPanel>
                        </StackPanel>
                        <TextBlock
                            Grid.Row="2"
                            Grid.Column="2"
                            IsTextSelectionEnabled="True"
                            Text="{x:Bind VM.TranslationResult.Translation, Mode=OneWay}"
                            TextWrapping="Wrap" />

                        <TextBlock
                            Grid.Row="4"
                            Foreground="{ThemeResource SecondaryForegroundBrush}"
                            Text="{StaticResource TranslationPage_QueryDescription}"
                            Visibility="{x:Bind VM.TranslationResult.QueryDescription, Mode=OneWay, Converter={StaticResource NullOrEmptyStringToCollapsedConverter}}" />
                        <TextBlock
                            Grid.Row="4"
                            Grid.Column="2"
                            IsTextSelectionEnabled="True"
                            Text="{x:Bind VM.TranslationResult.QueryDescription, Mode=OneWay}"
                            TextWrapping="Wrap"
                            Visibility="{x:Bind VM.TranslationResult.QueryDescription, Mode=OneWay, Converter={StaticResource NullOrEmptyStringToCollapsedConverter}}" />

                        <TextBlock
                            Grid.Row="6"
                            Foreground="{ThemeResource SecondaryForegroundBrush}"
                            Text="{StaticResource TranslationPage_TranslationDescription}"
                            Visibility="{x:Bind VM.TranslationResult.TranslationDescription, Mode=OneWay, Converter={StaticResource NullOrEmptyStringToCollapsedConverter}}" />
                        <TextBlock
                            Grid.Row="6"
                            Grid.Column="2"
                            IsTextSelectionEnabled="True"
                            Text="{x:Bind VM.TranslationResult.TranslationDescription, Mode=OneWay}"
                            TextWrapping="Wrap"
                            Visibility="{x:Bind VM.TranslationResult.TranslationDescription, Mode=OneWay, Converter={StaticResource NullOrEmptyStringToCollapsedConverter}}" />
                    </Grid>
                </ScrollViewer>
            </controls:CardControl.Content>
            <controls:CardControl.Fonter>
                <AppBarButton
                    HorizontalAlignment="Center"
                    Command="{x:Bind VM.CopyTranslationCommand}"
                    Label="{StaticResource TranslationPage_CopyTranslation}">
                    <AppBarButton.Icon>
                        <winui:FluentIcon Icon="Copy" />
                    </AppBarButton.Icon>
                </AppBarButton>
            </controls:CardControl.Fonter>
        </controls:CardControl>
    </Grid>
</Page>
