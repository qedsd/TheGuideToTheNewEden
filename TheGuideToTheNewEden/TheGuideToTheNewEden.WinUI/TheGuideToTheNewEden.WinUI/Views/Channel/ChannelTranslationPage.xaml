<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="TheGuideToTheNewEden.WinUI.Views.ChannelTranslationPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:channelintel="using:TheGuideToTheNewEden.Core.Models.ChannelIntel"
    xmlns:controls1="using:TheGuideToTheNewEden.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:TheGuideToTheNewEden.WinUI.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:TheGuideToTheNewEden.WinUI.Models"
    xmlns:viewmodels="using:TheGuideToTheNewEden.WinUI.ViewModels"
    Background="Transparent"
    NavigationCacheMode="Required"
    mc:Ignorable="d">
    <Page.DataContext>
        <viewmodels:ChannelTranslationViewModel x:Name="VM" />
    </Page.DataContext>
    <Grid x:Name="ContentGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <controls1:CardControl>
            <controls1:CardControl.Header>
                <TextBlock Text="{StaticResource Channel_Characters}" />
            </controls1:CardControl.Header>
            <controls1:CardControl.CustomContent>
                <ListView
                    x:Name="ProcessList"
                    Background="Transparent"
                    CanDragItems="True"
                    CanReorderItems="True"
                    ItemsSource="{x:Bind VM.Characters, Mode=OneWay}"
                    SelectedItem="{x:Bind VM.SelectedCharacter, Mode=TwoWay}"
                    Style="{StaticResource StretchListView}">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="20" />
                                    <ColumnDefinition />
                                </Grid.ColumnDefinitions>
                                <Rectangle
                                    Width="3"
                                    Height="16"
                                    HorizontalAlignment="Left"
                                    Fill="{ThemeResource SystemAccentColorLight2}"
                                    RadiusX="2"
                                    RadiusY="2"
                                    ToolTipService.ToolTip="{StaticResource ChannelMarket_Running}"
                                    Visibility="{Binding Running, Mode=OneWay, Converter={StaticResource TrueToVisibleConverter}}" />
                                <TextBlock
                                    Grid.Column="1"
                                    HorizontalAlignment="Stretch"
                                    Text="{Binding Name}" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </controls1:CardControl.CustomContent>
            <controls1:CardControl.Fonter>
                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                    <AppBarButton
                        Margin="0,0,16,0"
                        Command="{x:Bind VM.StartAllCommand}"
                        Icon="Play"
                        Label="{StaticResource General_StartAll}" />
                    <AppBarButton
                        Command="{x:Bind VM.StopAllCommand}"
                        Foreground="OrangeRed"
                        Icon="Stop"
                        Label="{StaticResource General_StopAll}"
                        Visibility="{x:Bind VM.Running, Mode=OneWay, Converter={StaticResource TrueToVisibleConverter}}" />
                    <AppBarButton
                        Margin="16,0,0,0"
                        HorizontalAlignment="Center"
                        Command="{x:Bind VM.RefreshCharactersCommand}"
                        Icon="Refresh"
                        Label="{StaticResource Channel_RefreshChannels}" />
                </StackPanel>
            </controls1:CardControl.Fonter>
        </controls1:CardControl>
        <controls1:CardControl
            Grid.Column="1"
            Width="300"
            Margin="4,0"
            Visibility="{x:Bind VM.ChannelTranslation, Mode=OneWay, Converter={StaticResource NullToCollapsedConverter}}">
            <controls1:CardControl.Header>
                <TextBlock Text="{StaticResource Channel_Channels}" />
            </controls1:CardControl.Header>
            <controls1:CardControl.CustomContent>
                <ListView IsEnabled="{x:Bind VM.SelectedCharacter.Running, Mode=OneWay, Converter={StaticResource BoolReverseConverte}}" ItemsSource="{x:Bind VM.ChatChanelInfos, Mode=OneWay}">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:ChatChanelInfo">
                            <Grid Margin="0,4">
                                <Grid.ContextFlyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem Click="MenuFlyoutItem_OpenFile_Click" Text="{StaticResource General_OpenFile}" />
                                        <MenuFlyoutItem Click="MenuFlyoutItem_OpenFoder_Click" Text="{StaticResource General_OpenFolder}" />
                                    </MenuFlyout>
                                </Grid.ContextFlyout>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="48" />
                                    <ColumnDefinition />
                                </Grid.ColumnDefinitions>
                                <CheckBox VerticalAlignment="Center" IsChecked="{x:Bind IsChecked, Mode=TwoWay}" />
                                <Grid Grid.Column="1" HorizontalAlignment="Left">
                                    <Grid.RowDefinitions>
                                        <RowDefinition />
                                        <RowDefinition />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="{x:Bind ChannelName}" ToolTipService.ToolTip="{StaticResource Channel_ChannelName}" />
                                    <TextBlock
                                        Grid.Row="1"
                                        Text="{x:Bind SessionStarted}"
                                        ToolTipService.ToolTip="{StaticResource Channel_LastUpdateTime}" />
                                </Grid>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </controls1:CardControl.CustomContent>
            <controls1:CardControl.Fonter>
                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                    <AppBarButton
                        HorizontalAlignment="Center"
                        Command="{x:Bind VM.RefreshChannelsCommand}"
                        Icon="Refresh"
                        IsEnabled="{x:Bind VM.SelectedCharacter.Running, Mode=OneWay, Converter={StaticResource BoolReverseConverte}}"
                        Label="{StaticResource Channel_RefreshChannels}" />
                </StackPanel>
            </controls1:CardControl.Fonter>
        </controls1:CardControl>
        <controls1:CardControl
            Grid.Column="2"
            Padding="4,4"
            Visibility="{x:Bind VM.ChannelTranslation, Mode=OneWay, Converter={StaticResource NullToCollapsedConverter}}">
            <controls1:CardControl.Header>
                <Grid>
                    <TextBlock VerticalAlignment="Center" Text="{StaticResource General_Setting}" />
                    <Button
                        Width="48"
                        Height="32"
                        HorizontalAlignment="Right"
                        Command="{x:Bind VM.ApplySettingToAllCommand}"
                        Style="{StaticResource TransparentButton}"
                        ToolTipService.ToolTip="{StaticResource Channel_ApplySettingToAll}">
                        <Button.Content>
                            <TextBlock
                                FontFamily="Segoe MDL2 Assets"
                                FontSize="18"
                                Text="&#xE81E;" />
                        </Button.Content>
                    </Button>
                </Grid>
            </controls1:CardControl.Header>
            <controls1:CardControl.CustomContent>
                <ScrollViewer>
                    <Grid>
                        <StackPanel x:Name="SettingArea">
                            <Expander
                                Margin="0,0,0,4"
                                Header="{StaticResource ChannelTranslation_Setting_General}"
                                IsEnabled="{x:Bind VM.SelectedCharacter.Running, Mode=OneWay, Converter={StaticResource BoolReverseConverte}}"
                                IsExpanded="True"
                                Style="{StaticResource StretchExpander}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="48" />
                                        <RowDefinition Height="48" />
                                        <RowDefinition Height="48" />
                                        <RowDefinition Height="48" />
                                    </Grid.RowDefinitions>
                                    <TextBlock
                                        Grid.Row="0"
                                        VerticalAlignment="Center"
                                        Text="{StaticResource ChannelTranslation_Setting_General_From}" />
                                    <ComboBox
                                        Grid.Row="0"
                                        Grid.Column="1"
                                        Width="140"
                                        Margin="8,0,0,0"
                                        VerticalAlignment="Center"
                                        ItemsSource="{x:Bind VM.Froms}"
                                        SelectedItem="{x:Bind VM.ChannelTranslation.Setting.AutoTranslateFrom, Mode=TwoWay}" />

                                    <TextBlock
                                        Grid.Row="1"
                                        VerticalAlignment="Center"
                                        Text="{StaticResource ChannelTranslation_Setting_General_To}" />
                                    <ComboBox
                                        Grid.Row="1"
                                        Grid.Column="1"
                                        Width="140"
                                        Margin="8,0,0,0"
                                        VerticalAlignment="Center"
                                        ItemsSource="{x:Bind VM.Tos}"
                                        SelectedItem="{x:Bind VM.ChannelTranslation.Setting.AutoTranslateTo, Mode=TwoWay}" />

                                    <TextBlock
                                        Grid.Row="2"
                                        VerticalAlignment="Center"
                                        Text="{StaticResource ChannelTranslation_Setting_General_KeyWord}" />
                                    <TextBox
                                        Grid.Row="2"
                                        Grid.Column="1"
                                        Height="32"
                                        Margin="8,0,0,0"
                                        PlaceholderText="{StaticResource ChannelTranslation_Setting_KeyWord_Tip}"
                                        Text="{x:Bind VM.ChannelTranslation.Setting.Keyword, Mode=TwoWay}" />

                                    <TextBlock
                                        Grid.Row="3"
                                        VerticalAlignment="Center"
                                        Text="{StaticResource ChannelTranslation_Setting_General_SkipMySelf}" />
                                    <CheckBox
                                        Grid.Row="3"
                                        Grid.Column="1"
                                        Margin="8,0,0,0"
                                        IsChecked="{x:Bind VM.ChannelTranslation.Setting.SkipMyself, Mode=TwoWay}" />
                                </Grid>
                            </Expander>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </controls1:CardControl.CustomContent>
            <controls1:CardControl.Fonter>
                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                    <AppBarButton
                        HorizontalAlignment="Center"
                        Command="{x:Bind VM.RestorePosCommand}"
                        Icon="Refresh"
                        Label="{StaticResource Channel_RestorePos}"
                        ToolTipService.ToolTip="{StaticResource Channel_RestorePos_Tip}"
                        Visibility="{x:Bind VM.SelectedCharacter.Running, Mode=OneWay, Converter={StaticResource TrueToVisibleConverter}}" />
                    <AppBarButton
                        HorizontalAlignment="Center"
                        Command="{x:Bind VM.StartCommand}"
                        Icon="Play"
                        Label="{StaticResource Channel_Start}"
                        Visibility="{x:Bind VM.SelectedCharacter.Running, Mode=OneWay, Converter={StaticResource FalseToVisibleConverter}}" />
                    <AppBarButton
                        Margin="16,0"
                        HorizontalAlignment="Center"
                        Command="{x:Bind VM.StopCommand}"
                        Foreground="OrangeRed"
                        Icon="Stop"
                        Label="{StaticResource Channel_Stop}"
                        Visibility="{x:Bind VM.SelectedCharacter.Running, Mode=OneWay, Converter={StaticResource TrueToVisibleConverter}}" />
                </StackPanel>
            </controls1:CardControl.Fonter>
        </controls1:CardControl>
    </Grid>
</Page>
