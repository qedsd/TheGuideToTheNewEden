<Page
    x:Class="TheGuideToTheNewEden.WinUI.Views.GameLogMonitorPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls1="using:TheGuideToTheNewEden.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dataGrid="using:Syncfusion.UI.Xaml.DataGrid"
    xmlns:local="using:TheGuideToTheNewEden.WinUI.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:TheGuideToTheNewEden.Core.Models"
    xmlns:viewmodels="using:TheGuideToTheNewEden.WinUI.ViewModels"
    xmlns:winui="using:FluentIcons.WinUI"
    Background="Transparent"
    NavigationCacheMode="Required"
    mc:Ignorable="d">
    <Page.DataContext>
        <viewmodels:GameLogMonitorViewModel x:Name="VM" />
    </Page.DataContext>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <controls1:CardControl>
            <controls1:CardControl.Header>
                <TextBlock Text="{StaticResource GameLogMonitorPage_CharacterList}" />
            </controls1:CardControl.Header>
            <controls1:CardControl.Content>
                <ListView
                    AllowDrop="True"
                    Background="Transparent"
                    CanDragItems="True"
                    CanReorderItems="True"
                    ItemsSource="{x:Bind VM.GameLogInfos, Mode=OneWay}"
                    SelectedItem="{x:Bind VM.SelectedGameLogInfo, Mode=TwoWay}"
                    Style="{StaticResource StretchListView}">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:GameLogInfo">
                            <Grid Margin="4,8">
                                <Grid.ContextFlyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem Click="MenuFlyoutItem_LogFile_Click" Text="{StaticResource GameLogMonitorPage_OpenLogFile}" />
                                    </MenuFlyout>
                                </Grid.ContextFlyout>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="20" />
                                    <ColumnDefinition />
                                </Grid.ColumnDefinitions>
                                <Rectangle
                                    Width="3"
                                    Height="26"
                                    HorizontalAlignment="Left"
                                    Fill="{ThemeResource SystemAccentColorLight2}"
                                    RadiusX="2"
                                    RadiusY="2"
                                    ToolTipService.ToolTip="{StaticResource GameLogMonitorPage_Running}"
                                    Visibility="{x:Bind Running, Mode=OneWay, Converter={StaticResource TrueToVisibleConverter}}" />
                                <Grid Grid.Column="1">
                                    <Grid.RowDefinitions>
                                        <RowDefinition />
                                        <RowDefinition />
                                    </Grid.RowDefinitions>
                                    <Grid>
                                        <TextBlock
                                            HorizontalAlignment="Stretch"
                                            Text="{x:Bind ListenerName}"
                                            ToolTipService.ToolTip="{x:Bind ListenerName}" />
                                    </Grid>
                                    <TextBlock
                                        Grid.Row="1"
                                        Margin="0,4,0,0"
                                        Text="{x:Bind StartTime, Mode=OneWay}"
                                        ToolTipService.ToolTip="{StaticResource GameLogMonitorPage_StartTime}" />
                                </Grid>
                            </Grid>

                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </controls1:CardControl.Content>
            <controls1:CardControl.Fonter>
                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                    <AppBarButton
                        Margin="8,0"
                        HorizontalAlignment="Center"
                        Command="{x:Bind VM.StartAllCommand}"
                        Label="{StaticResource General_StartAll}">
                        <AppBarButton.Icon>
                            <winui:FluentIcon Icon="Play" />
                        </AppBarButton.Icon>
                    </AppBarButton>
                    <AppBarButton
                        Margin="8,0"
                        HorizontalAlignment="Center"
                        Command="{x:Bind VM.StopAllCommand}"
                        Foreground="{ThemeResource DefaultRed}"
                        Label="{StaticResource General_StopAll}"
                        Visibility="{x:Bind VM.Running, Mode=OneWay, Converter={StaticResource TrueToVisibleConverter}}">
                        <AppBarButton.Icon>
                            <winui:FluentIcon Icon="Pause" />
                        </AppBarButton.Icon>
                    </AppBarButton>
                    <AppBarButton
                        Margin="8,0"
                        Background="Transparent"
                        BorderThickness="0"
                        Command="{x:Bind VM.RefreshCommand}"
                        Label="{StaticResource General_RefreshList}">
                        <AppBarButton.Icon>
                            <winui:FluentIcon Icon="ArrowSync" />
                        </AppBarButton.Icon>
                    </AppBarButton>
                </StackPanel>
            </controls1:CardControl.Fonter>
        </controls1:CardControl>
        <controls1:CardControl
            Grid.Column="1"
            Width="448"
            Margin="4,0"
            Visibility="{x:Bind VM.SelectedGameLogInfo, Mode=OneWay, Converter={StaticResource NullToCollapsedConverter}}">
            <controls1:CardControl.Header>
                <TextBlock Text="{StaticResource GameLogMonitorPage_Setting}" />
            </controls1:CardControl.Header>
            <controls1:CardControl.Content>
                <ScrollViewer Padding="4,0" IsEnabled="{x:Bind VM.SelectedGameLogInfo.Running, Mode=OneWay, Converter={StaticResource BoolReverseConverte}}">
                    <StackPanel>
                        <Expander
                            Margin="0,0,0,4"
                            Header="{StaticResource GameLogMonitorPage_MonitorMode}"
                            Style="{StaticResource StretchExpander}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <ComboBox
                                    HorizontalAlignment="Stretch"
                                    Header="{StaticResource GameLogMonitorPage_MonitorMode}"
                                    SelectedIndex="{x:Bind VM.GameLogSetting.MonitorMode, Mode=TwoWay}">
                                    <ComboBoxItem Content="{StaticResource GameLogMonitorPage_MonitorMode_0}" />
                                    <ComboBoxItem Content="{StaticResource GameLogMonitorPage_MonitorMode_1}" />
                                </ComboBox>
                                <NumberBox
                                    Grid.Row="1"
                                    Margin="0,10,0,0"
                                    Header="{StaticResource GameLogMonitorPage_DisappearDelay}"
                                    SmallChange="1"
                                    SpinButtonPlacementMode="Compact"
                                    Visibility="{x:Bind VM.GameLogSetting.MonitorMode, Mode=OneWay, Converter={StaticResource ZeroToCollapsedConverter}}"
                                    Value="{x:Bind VM.GameLogSetting.DisappearDelay, Mode=TwoWay}" />
                            </Grid>
                        </Expander>

                        <Expander
                            Margin="0,0,0,4"
                            Header="{StaticResource GameLogMonitorPage_NotifyMode}"
                            Style="{StaticResource StretchExpander}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition />
                                    <RowDefinition />
                                </Grid.RowDefinitions>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition />
                                        <ColumnDefinition />
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Content="{StaticResource GameLogMonitorPage_SystemNotify}" IsChecked="{x:Bind VM.GameLogSetting.SystemNotify, Mode=TwoWay}" />
                                    <CheckBox
                                        Grid.Column="1"
                                        Content="{StaticResource GameLogMonitorPage_WindowNotify}"
                                        IsChecked="{x:Bind VM.GameLogSetting.WindowNotify, Mode=TwoWay}" />
                                </Grid>
                                <Grid Grid.Row="1">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition />
                                            <ColumnDefinition />
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Content="{StaticResource GameLogMonitorPage_SoundNotify}" IsChecked="{x:Bind VM.GameLogSetting.SoundNotify, Mode=TwoWay}" />
                                        <CheckBox
                                            Grid.Column="1"
                                            Content="{StaticResource GameLogMonitorPage_RepeatSound}"
                                            IsChecked="{x:Bind VM.GameLogSetting.RepeatSound, Mode=TwoWay}"
                                            Visibility="{x:Bind VM.GameLogSetting.SoundNotify, Mode=OneWay, Converter={StaticResource TrueToVisibleConverter}}" />
                                    </Grid>

                                    <Grid
                                        Grid.Row="1"
                                        Margin="0,4,0,0"
                                        Visibility="{x:Bind VM.GameLogSetting.SoundNotify, Mode=OneWay, Converter={StaticResource TrueToVisibleConverter}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            Margin="0,0,4,0"
                                            VerticalAlignment="Center"
                                            Text="{StaticResource GameLogMonitorPage_SoundFile}" />
                                        <TextBox
                                            Grid.Column="1"
                                            IsEnabled="{x:Bind VM.GameLogSetting.SoundNotify, Mode=OneWay}"
                                            PlaceholderText="{StaticResource GameLogMonitorPage_Default}"
                                            Text="{x:Bind VM.GameLogSetting.SoundFile, Mode=TwoWay}" />
                                        <Button
                                            Grid.Column="2"
                                            Margin="4,0,0,0"
                                            Command="{x:Bind VM.PickSoundFileCommand}"
                                            Content="+"
                                            IsEnabled="{x:Bind VM.GameLogSetting.SoundNotify, Mode=OneWay}" />
                                    </Grid>
                                </Grid>
                            </Grid>
                        </Expander>
                        <Expander
                            Margin="0,0,0,4"
                            Header="{StaticResource GameLogMonitorPage_CharacterGameLog}"
                            Style="{StaticResource StretchExpander}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition />
                                </Grid.RowDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock VerticalAlignment="Center" Text="{StaticResource GameLogMonitorPage_NotifyKey}" />
                                    <Button
                                        Width="24"
                                        Height="24"
                                        Margin="4,0,0,0"
                                        Padding="0"
                                        BorderThickness="0"
                                        Content="!">
                                        <Button.Flyout>
                                            <Flyout>
                                                <TextBlock Text="{StaticResource GameLogMonitorPage_NotifyKey_Tip}" />
                                            </Flyout>
                                        </Button.Flyout>
                                    </Button>
                                </StackPanel>
                                <Button
                                    HorizontalAlignment="Right"
                                    Command="{x:Bind VM.AddKeysCommand}"
                                    Style="{ThemeResource TransparentButton}"
                                    ToolTipService.ToolTip="{StaticResource GameLogMonitorPage_AddKey}">
                                    <Button.Content>
                                        <winui:FluentIcon Icon="Add" IconSize="Resizable" />
                                    </Button.Content>
                                </Button>
                                <dataGrid:SfDataGrid
                                    Grid.Row="1"
                                    Margin="0,8,0,0"
                                    ItemsSource="{x:Bind VM.GameLogSetting.Keys, Mode=OneWay}"
                                    Style="{StaticResource SettingDataGrid}">
                                    <dataGrid:SfDataGrid.Columns>
                                        <dataGrid:GridTextColumn
                                            Width="350"
                                            HeaderText="{StaticResource GameLogMonitorPage_Regex}"
                                            MappingName="Pattern" />
                                        <dataGrid:GridTemplateColumn HeaderText="{StaticResource General_Remove}">
                                            <dataGrid:GridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button
                                                        HorizontalAlignment="Stretch"
                                                        VerticalAlignment="Stretch"
                                                        Click="Button_DeleteKey_Click"
                                                        Foreground="OrangeRed"
                                                        Style="{ThemeResource TransparentButton}">
                                                        <Button.Content>
                                                            <winui:FluentIcon Icon="Delete" IconSize="Resizable" />
                                                        </Button.Content>
                                                    </Button>
                                                </DataTemplate>
                                            </dataGrid:GridTemplateColumn.CellTemplate>
                                        </dataGrid:GridTemplateColumn>
                                    </dataGrid:SfDataGrid.Columns>
                                </dataGrid:SfDataGrid>
                            </Grid>
                        </Expander>

                        <Expander
                            Margin="0,0,0,4"
                            Header="{StaticResource GameLogMonitorPage_ThreadError}"
                            Style="{StaticResource StretchExpander}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal">
                                        <CheckBox Content="{StaticResource GameLogMonitorPage_MonitorThreadError}" IsChecked="{x:Bind VM.GameLogSetting.MonitorThreadError, Mode=TwoWay}" />
                                    </StackPanel>
                                    <Button
                                        Grid.Column="1"
                                        Command="{x:Bind VM.AddThreadErrorKeysCommand}"
                                        Style="{ThemeResource TransparentButton}"
                                        ToolTipService.ToolTip="{StaticResource GameLogMonitorPage_AddThreadErrorKey}"
                                        Visibility="{x:Bind VM.GameLogSetting.MonitorThreadError, Mode=OneWay, Converter={StaticResource TrueToVisibleConverter}}">
                                        <Button.Content>
                                            <winui:FluentIcon Icon="Add" IconSize="Resizable" />
                                        </Button.Content>
                                    </Button>
                                </Grid>
                                <dataGrid:SfDataGrid
                                    Grid.Row="1"
                                    Margin="0,8,0,0"
                                    ItemsSource="{x:Bind VM.GameLogSetting.ThreadErrorKeys, Mode=OneWay}"
                                    Style="{StaticResource SettingDataGrid}"
                                    Visibility="{x:Bind VM.GameLogSetting.MonitorThreadError, Mode=OneWay, Converter={StaticResource TrueToVisibleConverter}}">
                                    <dataGrid:SfDataGrid.Columns>
                                        <dataGrid:GridTextColumn
                                            Width="340"
                                            HeaderText="{StaticResource GameLogMonitorPage_Regex}"
                                            MappingName="Pattern" />
                                        <dataGrid:GridTemplateColumn HeaderText="{StaticResource General_Remove}">
                                            <dataGrid:GridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button
                                                        HorizontalAlignment="Stretch"
                                                        VerticalAlignment="Stretch"
                                                        Click="Button_DeleteThreadErrorKey_Click"
                                                        Foreground="OrangeRed"
                                                        Style="{ThemeResource TransparentButton}">
                                                        <Button.Content>
                                                            <winui:FluentIcon Icon="Delete" IconSize="Resizable" />
                                                        </Button.Content>
                                                    </Button>
                                                </DataTemplate>
                                            </dataGrid:GridTemplateColumn.CellTemplate>
                                        </dataGrid:GridTemplateColumn>
                                    </dataGrid:SfDataGrid.Columns>
                                </dataGrid:SfDataGrid>
                            </Grid>
                        </Expander>
                    </StackPanel>
                </ScrollViewer>
            </controls1:CardControl.Content>
            <controls1:CardControl.Fonter>
                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                    <AppBarButton
                        Margin="8,0"
                        HorizontalAlignment="Center"
                        Command="{x:Bind VM.StartCommand}"
                        Icon="Play"
                        Label="{StaticResource GameLogMonitorPage_Start}"
                        Visibility="{x:Bind VM.SelectedGameLogInfo.Running, Mode=OneWay, Converter={StaticResource FalseToVisibleConverter}}" />
                    <AppBarButton
                        Margin="8,0"
                        HorizontalAlignment="Center"
                        Command="{x:Bind VM.StopCommand}"
                        Foreground="OrangeRed"
                        Icon="Stop"
                        Label="{StaticResource GameLogMonitorPage_Stop}"
                        Visibility="{x:Bind VM.SelectedGameLogInfo.Running, Mode=OneWay, Converter={StaticResource TrueToVisibleConverter}}" />
                    <AppBarButton
                        Margin="8,0"
                        HorizontalAlignment="Center"
                        Command="{x:Bind VM.StopNotifyCommand}"
                        Icon="Mute"
                        Label="{StaticResource GameLogMonitorPage_StopNotify}"
                        ToolTipService.ToolTip="{StaticResource GameLogMonitorPage_StopNotify_Tip}"
                        Visibility="{x:Bind VM.SelectedGameLogInfo.Running, Mode=OneWay, Converter={StaticResource TrueToVisibleConverter}}" />
                </StackPanel>
            </controls1:CardControl.Fonter>
        </controls1:CardControl>
        <controls1:CardControl Grid.Column="2" Visibility="{x:Bind VM.SelectedGameLogInfo, Mode=OneWay, Converter={StaticResource NullToCollapsedConverter}}">
            <controls1:CardControl.Header>
                <TextBlock Text="{StaticResource GameLogMonitorPage_Logs}" />
            </controls1:CardControl.Header>
            <controls1:CardControl.Content>
                <ScrollViewer x:Name="GameLogContentsScroll">
                    <RichTextBlock
                        x:Name="GameLogContents"
                        Margin="4,0"
                        IsRightTapEnabled="False" />
                </ScrollViewer>
            </controls1:CardControl.Content>
        </controls1:CardControl>

    </Grid>
</Page>
