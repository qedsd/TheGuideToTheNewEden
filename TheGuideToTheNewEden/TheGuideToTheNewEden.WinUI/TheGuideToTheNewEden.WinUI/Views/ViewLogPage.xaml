<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="TheGuideToTheNewEden.WinUI.Views.ViewLogPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:TheGuideToTheNewEden.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:TheGuideToTheNewEden.WinUI.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:winui="using:FluentIcons.WinUI"
    Background="Transparent"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <ScrollViewer x:Name="LogTextScrollViewer">
            <RichTextBlock x:Name="LogTextBlock" Margin="8,4" />
        </ScrollViewer>
        <StackPanel
            Grid.Row="1"
            Margin="4"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <StackPanel.Resources>
                <Style BasedOn="{StaticResource DefaultButtonStyle}" TargetType="Button">
                    <Setter Property="Margin" Value="1,0" />
                </Style>
            </StackPanel.Resources>
            <Button Click="OpenFolderButton_Click" ToolTipService.ToolTip="{StaticResource General_OpenFolder}">
                <winui:FluentIcon Icon="Folder" />
            </Button>
            <Button Click="OpenFileButton_Click" ToolTipService.ToolTip="{StaticResource General_OpenFile}">
                <winui:FluentIcon Icon="Document" />
            </Button>
            <Button Click="ClearButton_Click" ToolTipService.ToolTip="{StaticResource LogViewPage_ClearLog}">
                <winui:FluentIcon Icon="Eraser" />
            </Button>
        </StackPanel>
    </Grid>
</Page>
