<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="TheGuideToTheNewEden.WinUI.Views.Tools.KeyboardSpanPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:TheGuideToTheNewEden.WinUI.Views.Tools"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:winui="using:FluentIcons.WinUI"
    Background="Transparent"
    mc:Ignorable="d">

    <Grid>
        <Grid x:Name="SettingGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="1">
                <AppBarButton
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Click="Start_Click"
                    Foreground="{ThemeResource DefaultGreen}"
                    Icon="Play"
                    Label="{StaticResource Channel_Start}" />
            </Border>
            <ScrollViewer
                Grid.Column="0"
                Padding="8"
                Background="{ThemeResource CardBackgroundFillColorDefault}"
                CornerRadius="8">
                <Grid>
                    <Grid.Resources>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center" />
                            <Setter Property="Margin" Value="0,0,4,0" />
                        </Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Orientation" Value="Horizontal" />
                        </Style>
                    </Grid.Resources>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBox
                        x:Name="KeyboardTextBox"
                        VerticalAlignment="Center"
                        Header="{StaticResource KeyboardSpanPage_Keyboard}"
                        Text="F1" />

                    <ComboBox
                        x:Name="ModeComboBox"
                        Grid.Row="1"
                        Margin="0,8,0,0"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Center"
                        Header="{StaticResource KeyboardSpanPage_Mode}"
                        SelectedIndex="0">
                        <ComboBoxItem Content="{StaticResource KeyboardSpanPage_Mode1}" />
                        <ComboBoxItem Content="{StaticResource KeyboardSpanPage_Mode2}" />
                    </ComboBox>

                    <NumberBox
                        x:Name="CountNumberBox"
                        Grid.Row="2"
                        Margin="0,8,0,0"
                        VerticalAlignment="Center"
                        Header="{StaticResource KeyboardSpanPage_Count}"
                        Minimum="1"
                        Value="6" />

                    <NumberBox
                        x:Name="SpanNumberBox"
                        Grid.Row="3"
                        Margin="0,8,0,0"
                        VerticalAlignment="Center"
                        Header="{StaticResource KeyboardSpanPage_Span}"
                        Minimum="0.1"
                        PlaceholderText="s"
                        Value="1" />

                    <ComboBox
                        x:Name="CharacterComboBox"
                        Grid.Row="4"
                        Margin="0,8,46,0"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Center"
                        Header="{StaticResource KeyboardSpanPage_Character}"
                        SelectedIndex="0" />
                    <Button
                        Grid.Row="4"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Click="UpdateCharacters_Click">
                        <winui:FluentIcon Icon="ArrowSync" />
                    </Button>
                </Grid>
            </ScrollViewer>

