        <Grid x:Name="RunningGrid" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Button
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Click="DataButton_Click">
                <StackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <StackPanel.Resources>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontSize" Value="40" />
                        </Style>
                    </StackPanel.Resources>
                    <TextBlock x:Name="PassCountTextBlock" Text="0" />
                    <TextBlock Margin="4,0" Text="/" />
                    <TextBlock x:Name="TargetCountTextBlock" Text="0" />
                </StackPanel>
            </Button>
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel
                    Margin="4,0,0,0"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <TextBlock
                        x:Name="TotalDuratioTextBlock"
                        Text="00:00:00"
                        ToolTipService.ToolTip="{StaticResource KeyboardSpanPage_TotalDuration}" />
                    <Rectangle
                        Width="1"
                        Margin="8,4,8,2"
                        Fill="{ThemeResource DefaultGray}" />
                    <TextBlock
                        x:Name="TotalKeyboardCountTextBlock"
                        Text="0"
                        ToolTipService.ToolTip="{StaticResource KeyboardSpanPage_TotalKeyboardCount}" />
                </StackPanel>
                <Button
                    Grid.Column="1"
                    Click="Stop_Click"
                    Foreground="{ThemeResource DefaultRed}"
                    Style="{ThemeResource TransparentButton}">
                    <winui:FluentIcon Icon="Stop" />
                </Button>
            </Grid>

