<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="TheGuideToTheNewEden.WinUI.Views.Tools.IMEPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ic="using:FluentIcons.WinUI"
    xmlns:local="using:TheGuideToTheNewEden.WinUI.Views.Tools"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="Transparent"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid>
            <TextBox
                x:Name="InputTextBox"
                AcceptsReturn="True"
                Style="{StaticResource NoDeleteTextBox}"
                TextChanged="InputTextBox_TextChanged"
                TextWrapping="Wrap" />
            <Grid
                x:Name="DetailGrid"
                Margin="4,0"
                Visibility="Collapsed">
                <ScrollViewer>
                    <RichTextBlock x:Name="DetailContent" Grid.Row="1" />
                </ScrollViewer>
            </Grid>
        </Grid>
        <Grid Grid.Row="1" Margin="0,2">
            <Grid x:Name="InputOpGrid">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ScrollViewer
                    HorizontalScrollBarVisibility="Hidden"
                    HorizontalScrollMode="Enabled"
                    VerticalScrollBarVisibility="Disabled"
                    VerticalScrollMode="Disabled">
                    <ItemsControl x:Name="SuggestionsContainer">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button
                                    Margin="2,0"
                                    HorizontalAlignment="Stretch"
                                    Click="SuggestionButton_Click"
                                    Content="{Binding Name}"
                                    FontSize="12"
                                    ToolTipService.ToolTip="{Binding Id}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button
                        Margin="4,0,0,0"
                        Click="SearchButton_Click"
                        Style="{StaticResource TransparentButton}"
                        ToolTipService.ToolTip="{StaticResource IMEPage_Serach}">
                        <ic:FluentIcon Icon="Search" />
                    </Button>
                    <Button
                        Margin="4,0,0,0"
                        Click="TranslateButton_Click"
                        Style="{StaticResource TransparentButton}"
                        ToolTipService.ToolTip="{StaticResource IMEPage_Translate}">
                        <ic:FluentIcon Icon="Translate" />
                    </Button>
                    <Button
                        Margin="4,0,0,0"
                        Click="CopyButton_Click"
                        Style="{StaticResource TransparentButton}"
                        ToolTipService.ToolTip="{StaticResource IMEPage_Copy}">
                        <ic:FluentIcon Icon="Copy" />
                    </Button>
                </StackPanel>
            </Grid>
            <Grid
                x:Name="DetailOpGrid"
                Margin="4,0"
                Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    x:Name="DetailTitle"
                    VerticalAlignment="Center"
                    FontSize="12"
                    IsTextSelectionEnabled="True"
                    Opacity="0.6" />
                <Button
                    Grid.Column="1"
                    Click="ExitDetailButton_Click"
                    Style="{StaticResource TransparentButton}">
                    <ic:FluentIcon Icon="ArrowHookDownLeft" />
                </Button>
            </Grid>
        </Grid>
    </Grid>
</Page>
