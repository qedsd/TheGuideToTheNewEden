<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="TheGuideToTheNewEden.WinUI.Views.Map.Tools.MapNavigation"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:TheGuideToTheNewEden.WinUI.Controls"
    xmlns:converters="using:TheGuideToTheNewEden.WinUI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dataGrid="using:Syncfusion.UI.Xaml.DataGrid"
    xmlns:editors="using:Syncfusion.UI.Xaml.Editors"
    xmlns:local="using:TheGuideToTheNewEden.WinUI.Views.Map.Tools"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="Transparent"
    mc:Ignorable="d">
    <Page.Resources>
        <converters:MapNavTypeConverter x:Key="MapNavTypeConverter" />
    </Page.Resources>
    <Grid Margin="4,0,4,4">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <controls:CardControl>
            <controls:CardControl.Header>
                <TextBlock Text="{StaticResource General_Setting}" />
            </controls:CardControl.Header>
            <controls:CardControl.CustomContent>
                <ScrollViewer Padding="8,0,8,8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <!--  航点设置  -->
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition />
                                </Grid.ColumnDefinitions>
                                <TextBlock VerticalAlignment="Center" Text="{StaticResource MapNavigation_AddWaypoint}" />
                                <controls:MapSystemSelectorControl
                                    x:Name="MapSystemSelector"
                                    Grid.Column="1"
                                    Height="34"
                                    Margin="0,4"
                                    OnSelectedItemChanged="MapSystemSelector_OnSelectedItemChanged"
                                    ShowSpecial="False" />
                            </Grid>
                            <ListView
                                x:Name="WaypointsListView"
                                Grid.Row="1"
                                AllowDrop="True"
                                CanDrag="True"
                                CanDragItems="True"
                                CanReorderItems="True">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding SolarSystemName}" />
                                            <Button
                                                Grid.Column="1"
                                                Click="RemoveWaypointButton_Click"
                                                Style="{ThemeResource TransparentButton}">
                                                <Button.Content>
                                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE10A;" />
                                                </Button.Content>
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                        <Rectangle
                            Grid.Row="1"
                            Height="1"
                            Margin="4,8"
                            Fill="LightGray" />
                        <!--  通用导航设置  -->
                        <Grid Grid.Row="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid Margin="0,4">
                                <TextBlock VerticalAlignment="Center" Text="{StaticResource MapNavigation_NavType}" />
                                <ComboBox
                                    x:Name="NavTypeComboBox"
                                    MinWidth="100"
                                    HorizontalAlignment="Right"
                                    SelectedIndex="0">
                                    <ComboBoxItem Content="{StaticResource MapNavigation_NavType_Stargate}" />
                                    <ComboBoxItem Content="{StaticResource MapNavigation_NavType_CapitalJump}" />
                                </ComboBox>
                            </Grid>
                            <Grid Grid.Row="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid Margin="0,4">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock VerticalAlignment="Center" Text="{StaticResource MapNavigation_AvoidSystem}" />
                                        <Button
                                            x:Name="AvoidSystemButton"
                                            Grid.Column="1"
                                            Width="100"
                                            Margin="8,0,0,0"
                                            HorizontalAlignment="Right"
                                            Content="0">
                                            <Button.Flyout>
                                                <Flyout>
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition />
                                                        </Grid.RowDefinitions>
                                                        <controls:MapSystemSelectorControl
                                                            x:Name="AvoidSystemSelector"
                                                            Grid.Column="1"
                                                            Width="200"
                                                            Height="32"
                                                            Margin="0,4"
                                                            OnSelectedItemChanged="AvoidSystemSelector_OnSelectedItemChanged"
                                                            ShowSpecial="False" />
                                                        <ListView x:Name="AvoidSystemListView" Grid.Row="1">
                                                            <ListView.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition />
                                                                            <ColumnDefinition Width="Auto" />
                                                                        </Grid.ColumnDefinitions>
                                                                        <TextBlock Text="{Binding SolarSystemName}" />
                                                                        <Button
                                                                            Grid.Column="1"
                                                                            Click="RemoveAvoidSystemButton_Click"
                                                                            Style="{ThemeResource TransparentButton}">
                                                                            <Button.Content>
                                                                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE10A;" />
                                                                            </Button.Content>
                                                                        </Button>
                                                                    </Grid>
                                                                </DataTemplate>
                                                            </ListView.ItemTemplate>
                                                        </ListView>
                                                    </Grid>
                                                </Flyout>
                                            </Button.Flyout>
                                        </Button>
                                    </Grid>

                                </Grid>
                                <Grid Grid.Row="1" Margin="0,4">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock VerticalAlignment="Center" Text="{StaticResource MapNavigation_AvoidRegion}" />
                                        <Button
                                            x:Name="AvoidRegionButton"
                                            Grid.Column="1"
                                            Width="100"
                                            Margin="8,0,0,0"
                                            HorizontalAlignment="Right"
                                            Content="0">
                                            <Button.Flyout>
                                                <Flyout>
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition />
                                                        </Grid.RowDefinitions>
                                                        <controls:SelecteRegionControl
                                                            x:Name="AvoidRegionSelector"
                                                            Grid.Column="1"
                                                            Width="200"
                                                            Height="32"
                                                            Margin="0,4"
                                                            OnSelectedItemChanged="AvoidRegionSelector_OnSelectedItemChanged" />
                                                        <ListView x:Name="AvoidRegionListView" Grid.Row="1">
                                                            <ListView.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition />
                                                                            <ColumnDefinition Width="Auto" />
                                                                        </Grid.ColumnDefinitions>
                                                                        <TextBlock Text="{Binding RegionName}" />
                                                                        <Button
                                                                            Grid.Column="1"
                                                                            Click="RemoveAvoidRegionButton_Click"
                                                                            Style="{ThemeResource TransparentButton}">
                                                                            <Button.Content>
                                                                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE10A;" />
                                                                            </Button.Content>
                                                                        </Button>
                                                                    </Grid>
                                                                </DataTemplate>
                                                            </ListView.ItemTemplate>
                                                        </ListView>
                                                    </Grid>
                                                </Flyout>
                                            </Button.Flyout>
                                        </Button>
                                    </Grid>
                                </Grid>
                            </Grid>
                        </Grid>
                        <!--  旗舰跳设置  -->
                        <Grid
                            x:Name="CapitalJumpGrid"
                            Grid.Row="3"
                            Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition />
                                </Grid.ColumnDefinitions>
                                <TextBlock VerticalAlignment="Center" Text="{StaticResource MapNavigation_ShipType}" />
                                <ComboBox
                                    x:Name="ShipTypeComboBox"
                                    Grid.Column="1"
                                    MinWidth="100"
                                    Margin="8,0,0,0"
                                    HorizontalAlignment="Right"
                                    DisplayMemberPath="Name"
                                    SelectedIndex="0"
                                    SelectionChanged="ShipTypeComboBox_SelectionChanged" />
                            </Grid>
                            <Grid Grid.Row="1" Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    VerticalAlignment="Center"
                                    Text="{StaticResource MapNavigation_JumpDriveCalibration}"
                                    ToolTipService.ToolTip="{StaticResource MapNavigation_JumpDriveCalibration_Tip}" />
                                <NumberBox
                                    x:Name="JumpDriveCalibrationNumberBox"
                                    Grid.Column="1"
                                    LargeChange="1"
                                    Maximum="5"
                                    Minimum="0"
                                    SmallChange="1"
                                    SpinButtonPlacementMode="Compact"
                                    ValueChanged="JumpDriveCalibrationNumberBox_ValueChanged"
                                    Value="4" />
                            </Grid>
                            <Grid Grid.Row="2" Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    VerticalAlignment="Center"
                                    Text="{StaticResource MapNavigation_JumpFuelConservation}"
                                    ToolTipService.ToolTip="{StaticResource MapNavigation_JumpFuelConservation_Tip}" />
                                <NumberBox
                                    x:Name="JumpFuelConservationNumberBox"
                                    Grid.Column="1"
                                    LargeChange="1"
                                    Maximum="5"
                                    Minimum="0"
                                    SmallChange="1"
                                    SpinButtonPlacementMode="Compact"
                                    ValueChanged="JumpFuelConservationNumberBox_ValueChanged"
                                    Value="4" />
                            </Grid>
                            <Grid
                                x:Name="JumpFreightersGrid"
                                Grid.Row="3"
                                Margin="0,4"
                                Visibility="Collapsed">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    VerticalAlignment="Center"
                                    Text="{StaticResource MapNavigation_JumpFreighters}"
                                    ToolTipService.ToolTip="{StaticResource MapNavigation_JumpFreighters_Tip}" />
                                <NumberBox
                                    x:Name="JumpFreightersNumberBox"
                                    Grid.Column="1"
                                    LargeChange="1"
                                    Maximum="5"
                                    Minimum="0"
                                    SmallChange="1"
                                    SpinButtonPlacementMode="Compact"
                                    ValueChanged="JumpFreightersNumberBox_ValueChanged"
                                    Value="4" />
                            </Grid>
                            <!--  暂时屏蔽模式选择，默认省时优先  -->
                            <Grid
                                Grid.Row="4"
                                Margin="0,4"
                                Visibility="Collapsed">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition />
                                </Grid.ColumnDefinitions>
                                <TextBlock VerticalAlignment="Center" Text="{StaticResource MapNavigation_PreferPath}" />
                                <ComboBox
                                    x:Name="PreferPathComboBox"
                                    Grid.Column="1"
                                    Margin="8,0,0,0"
                                    HorizontalAlignment="Right"
                                    SelectedIndex="0">
                                    <ComboBoxItem>
                                        <TextBlock Text="{StaticResource MapNavigation_PreferPath_Faster}" />
                                    </ComboBoxItem>
                                    <ComboBoxItem>
                                        <TextBlock Text="{StaticResource MapNavigation_PreferPath_Cheaper}" />
                                    </ComboBoxItem>
                                </ComboBox>
                            </Grid>
                            <Grid Grid.Row="5" Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition />
                                </Grid.ColumnDefinitions>
                                <TextBlock VerticalAlignment="Center" Text="{StaticResource MapNavigation_UseStargate}" />
                                <CheckBox
                                    x:Name="UseStargateCheckBox"
                                    Grid.Column="1"
                                    Margin="8,0,0,0"
                                    IsChecked="True" />
                            </Grid>
                            <Grid Grid.Row="6" Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition />
                                </Grid.ColumnDefinitions>
                                <TextBlock VerticalAlignment="Center" Text="{StaticResource MapNavigation_MaxJump}" />
                                <StackPanel
                                    Grid.Column="1"
                                    HorizontalAlignment="Right"
                                    Orientation="Horizontal">
                                    <TextBlock x:Name="MaxJumpTextBlock" VerticalAlignment="Center" />
                                    <TextBlock
                                        Margin="8,0,0,0"
                                        VerticalAlignment="Center"
                                        Text="ly" />
                                </StackPanel>

                            </Grid>
                            <Grid Grid.Row="7" Margin="0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition />
                                </Grid.ColumnDefinitions>
                                <TextBlock VerticalAlignment="Center" Text="{StaticResource MapNavigation_PerLyFuel}" />
                                <TextBlock
                                    x:Name="PerLyFuelTextBlock"
                                    Grid.Column="1"
                                    HorizontalAlignment="Right" />
                            </Grid>
                        </Grid>
                        <Rectangle
                            Grid.Row="4"
                            Height="1"
                            Margin="4,8"
                            Fill="LightGray" />
                        <Grid Grid.Row="5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center" Text="{StaticResource MapNavigation_Result_SelecteCharacter}" />
                            <controls:SelecteCharacterControl
                                x:Name="ShowInGameSelecteCharacterControl"
                                Grid.Column="1"
                                Width="200"
                                Margin="8,0,0,0"
                                HorizontalAlignment="Right" />
                        </Grid>
                    </Grid>
                </ScrollViewer>
            </controls:CardControl.CustomContent>
            <controls:CardControl.Fonter>
                <Button
                    HorizontalAlignment="Stretch"
                    Click="StartNavigateButton_Click"
                    Content="{StaticResource MapNavigation_Go}"
                    Style="{ThemeResource AccentButtonStyle}" />
            </controls:CardControl.Fonter>
        </controls:CardControl>
        <controls:CardControl Grid.Column="1" Margin="4,0,0,0">
            <controls:CardControl.Header>
                <TextBlock Text="{StaticResource General_Result}" />
            </controls:CardControl.Header>
            <controls:CardControl.CustomContent>
                <TabView
                    x:Name="ResultTabView"
                    CloseButtonOverlayMode="OnPointerOver"
                    IsAddTabButtonVisible="False"
                    TabCloseRequested="ResultTabView_TabCloseRequested" />
            </controls:CardControl.CustomContent>
            <controls:CardControl.Fonter>
                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                    <Button Click="ShowInGame_Click" Content="{StaticResource MapNavigation_Result_ShowInGame}" />
                    <Button
                        Margin="8,0"
                        Click="ShowInMap_Click"
                        Content="{StaticResource MapNavigation_Result_ShowInMap}" />
                    <Button Click="RemoveFromMap_Click" Content="{StaticResource MapNavigation_Result_RemoveFromMap}" />
                </StackPanel>
            </controls:CardControl.Fonter>
        </controls:CardControl>
    </Grid>
</Page>
