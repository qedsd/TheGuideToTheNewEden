<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="TheGuideToTheNewEden.WinUI.Views.Map.Tools.IntelTool"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:TheGuideToTheNewEden.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:TheGuideToTheNewEden.WinUI.Views.Map.Tools"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="Transparent"
    mc:Ignorable="d">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <controls:CardControl>
            <controls:CardControl.Header>
                <TextBlock Text="{StaticResource MapIntelTool_Setting}" />
            </controls:CardControl.Header>
            <controls:CardControl.Content>
                <StackPanel>
                    <Expander Header="{StaticResource MapIntelTool_ChannelIntel}" />
                </StackPanel>
            </controls:CardControl.Content>
            <controls:CardControl.Fonter>
                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                    <AppBarButton Icon="Play" Label="{StaticResource General_Start}" />
                    <AppBarButton
                        Foreground="OrangeRed"
                        Icon="Stop"
                        Label="{StaticResource General_Stop}" />
                </StackPanel>
            </controls:CardControl.Fonter>
        </controls:CardControl>
        <controls:CardControl Grid.Column="1">
            <controls:CardControl.Header>
                <TextBlock Text="{StaticResource MapIntelTool_LiveData}" />
            </controls:CardControl.Header>
            <controls:CardControl.Content>
                <ListView x:Name="LiveDataListView" />
            </controls:CardControl.Content>
            <controls:CardControl.Fonter>
                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                    <AppBarButton Icon="Clear" Label="{StaticResource MapIntelTool_ClearList}" />
                    <AppBarButton Icon="Map" Label="{StaticResource MapIntelTool_ClearMap}" />
                </StackPanel>
            </controls:CardControl.Fonter>
        </controls:CardControl>
    </Grid>
</Page>
