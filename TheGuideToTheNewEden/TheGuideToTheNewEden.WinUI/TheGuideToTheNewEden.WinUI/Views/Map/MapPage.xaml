<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="TheGuideToTheNewEden.WinUI.Views.Map.MapPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:TheGuideToTheNewEden.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dataGrid="using:Syncfusion.UI.Xaml.DataGrid"
    xmlns:ic="using:FluentIcons.WinUI"
    xmlns:local="using:TheGuideToTheNewEden.WinUI.Views.Map"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:tools="using:TheGuideToTheNewEden.WinUI.Views.Map.Tools"
    Background="Transparent"
    NavigationCacheMode="Required"
    mc:Ignorable="d">

    <Grid>
        <local:MapCanvas
            x:Name="MapCanvas"
            OnPointedSystemChanged="MapCanvas_OnPointedSystemChanged"
            OnSelectedSystemChanged="MapCanvas_OnSelectedSystemChanged" />

        <!--  左上角工具栏  -->
        <StackPanel Margin="2,0,0,0" VerticalAlignment="Top">
            <StackPanel Padding="4" Orientation="Horizontal">
                <Button Style="{ThemeResource TransparentButton}" ToolTipService.ToolTip="{StaticResource MapPage_SystemFilter}">
                    <Button.Content>
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE16E;" />
                    </Button.Content>
                    <Button.Flyout>
                        <Flyout Placement="BottomEdgeAlignedLeft">
                            <controls:SystemFilterControl
                                x:Name="SystemFilterControl"
                                Grid.Row="1"
                                Width="400"
                                OnFilterSystemChanged="SystemFilterControl_OnFilterSystemChanged" />
                        </Flyout>
                    </Button.Flyout>
                </Button>
                <Button Style="{ThemeResource TransparentButton}" ToolTipService.ToolTip="{StaticResource MapPage_Setting}">
                    <Button.Content>
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE115;" />
                    </Button.Content>
                    <Button.Flyout>
                        <Flyout Placement="BottomEdgeAlignedLeft">
                            <ScrollView>
                                <StackPanel MinWidth="400">
                                    <Expander
                                        Margin="0,4"
                                        Header="{StaticResource MapPage_Setting_SystemIconContent}"
                                        Style="{StaticResource StretchExpander}">
                                        <controls:MapDataTypeControl
                                            x:Name="MapDataTypeControl"
                                            Width="400"
                                            OnDataTypChanged="MapDataTypeControl_OnDataTypChanged"
                                            OnPlanetResourceTypeChanged="MapDataTypeControl_OnPlanetResourceTypeChanged"
                                            OnSOVDatasChanged="MapDataTypeControl_OnSOVDatasChanged" />
                                    </Expander>
                                    <Expander
                                        Margin="0,4"
                                        Header="{StaticResource MapPage_Setting_JumpBridge}"
                                        Style="{StaticResource StretchExpander}">
                                        <controls:JumpBridgeSetting />
                                    </Expander>
                                    <Expander
                                        Margin="0,4"
                                        Header="{StaticResource MapPage_Setting_Tool}"
                                        Style="{StaticResource StretchExpander}">
                                        <ToggleSwitch
                                            IsOn="False"
                                            OffContent="{StaticResource MapPage_DisableNoActiveSystem}"
                                            OnContent="{StaticResource MapPage_EnableNoActiveSystem}"
                                            Toggled="DisableNoActiveSystem_Toggled" />
                                    </Expander>
                                    <Expander
                                        Margin="0,4"
                                        Header="{StaticResource MapPage_Setting_Characters}"
                                        Style="{StaticResource StretchExpander}">
                                        <ToggleSwitch
                                            IsOn="True"
                                            OffContent="{StaticResource MapPage_Setting_Characters_NotShow}"
                                            OnContent="{StaticResource MapPage_Setting_Characters_Show}"
                                            Toggled="ShowCharacters_Toggled" />
                                    </Expander>
                                </StackPanel>
                            </ScrollView>
                        </Flyout>
                    </Button.Flyout>
                </Button>
                <Button Style="{ThemeResource TransparentButton}" ToolTipService.ToolTip="{StaticResource MapPage_Tools}">
                    <Button.Content>
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE74C;" />
                    </Button.Content>
                    <Button.Flyout>
                        <MenuFlyout Placement="BottomEdgeAlignedLeft">
                            <MenuFlyoutItem
                                Click="Tools_Click"
                                Tag="Clear"
                                Text="{StaticResource MapPage_Tools_Clear}" />
                            <MenuFlyoutSeparator />
                            <MenuFlyoutItem
                                Click="Tools_Click"
                                Tag="PlanetResource"
                                Text="{StaticResource MapPage_Tools_PlanetResource}" />
                            <MenuFlyoutItem
                                Click="Tools_Click"
                                Tag="Navigation"
                                Text="{StaticResource MapPage_Tools_Navigation}" />
                            <MenuFlyoutItem
                                Click="Tools_Click"
                                Tag="OneJumpCover"
                                Text="{StaticResource MapPage_Tools_InOneJumpSystems}" />
                            <MenuFlyoutItem
                                Click="Tools_Click"
                                Tag="Intel"
                                Text="{StaticResource MapPage_Tools_Intel}" />
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>
            </StackPanel>
        </StackPanel>
        <Grid
            Height="34"
            HorizontalAlignment="Right"
            VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <ComboBox x:Name="SearchTypeComboBox" SelectedIndex="0">
                <ComboBoxItem Content="{StaticResource MapPage_SearchSystem}" />
                <ComboBoxItem Content="{StaticResource MapPage_SearchRegion}" />
            </ComboBox>
            <Grid
                Grid.Column="1"
                Width="200"
                Margin="-4,0,-8,0">
                <controls:MapSystemSelectorControl x:Name="MapSystemSelector" ShowSpecial="True" />
                <controls:SelecteRegionControl
                    x:Name="RegionSelector"
                    ShowList="False"
                    Visibility="Collapsed" />
            </Grid>
        </Grid>

        <!--  左侧预警信息面板  -->
        <Grid
            x:Name="SelectedSystemIntelPanel"
            MinWidth="260"
            MaxWidth="400"
            Margin="8,42,0,8"
            HorizontalAlignment="Left"
            VerticalAlignment="Bottom"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            CornerRadius="8"
            Visibility="Collapsed">
            <Grid
                Margin="8"
                Padding="8,8,8,8"
                Background="{ThemeResource AcrylicInAppFillColorDefaultBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock
                    Margin="0,4"
                    HorizontalAlignment="Center"
                    FontSize="18"
                    FontWeight="Medium"
                    Foreground="{ThemeResource SystemAccentColor}"
                    Text="{StaticResource MapIntelTool_IntelInfo}" />
                <ScrollViewer Grid.Row="1" HorizontalScrollMode="Disabled">
                    <StackPanel>
                        <Grid x:Name="SelectedSystemIntelShipGrid" Grid.Row="0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition/>
                                </Grid.RowDefinitions>
                                <TextBlock
                                    Margin="0,0,0,4"
                                    Foreground="{ThemeResource SecondaryForegroundBrush}"
                                    Text="{StaticResource MapIntelTool_IntelShip}" />
                                <ListView
                                    x:Name="SelectedSystemIntelShipListView"
                                    Grid.Row="1"
                                    Style="{StaticResource StretchListView}">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <controls:ImageControl Width="32" Source="{Binding ShipType.Id, Converter={StaticResource TypeImgConverter32}}" />
                                                <TextBlock
                                                    Grid.Column="1"
                                                    Margin="8,0"
                                                    VerticalAlignment="Center"
                                                    Text="{Binding ShipType.Name}" />
                                                <TextBlock
                                                    Grid.Column="2"
                                                    VerticalAlignment="Center"
                                                    Text="×" />
                                                <TextBlock
                                                    Grid.Column="3"
                                                    VerticalAlignment="Center"
                                                    Text="{Binding Count}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Grid>
                        </Grid>
                        <Grid
                            x:Name="SelectedSystemIntelMsgGrid"
                            Grid.Row="1"
                            Margin="0,8,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition/>
                                </Grid.RowDefinitions>
                                <TextBlock
                                    Margin="0,0,0,4"
                                    Foreground="{ThemeResource SecondaryForegroundBrush}"
                                    Text="{StaticResource MapIntelTool_IntelMsg}" />
                                <ListView
                                    x:Name="SelectedSystemIntelMsgListView"
                                    Grid.Row="1"
                                    Style="{StaticResource StretchListView}">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock
                                                Margin="0,4"
                                                Text="{Binding}"
                                                TextWrapping="Wrap" />
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Grid>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!--  右侧详细面板  -->
        <Grid
            x:Name="SelectedSystemInfoPanel"
            Width="260"
            Margin="16"
            Padding="8"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            CornerRadius="8"
            Visibility="Collapsed">
            <Grid Padding="8" Background="{ThemeResource AcrylicInAppFillColorDefaultBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock
                    x:Name="SelectedSystemNameTextBlock"
                    Margin="0,4"
                    HorizontalAlignment="Center"
                    FontSize="18"
                    FontWeight="Medium"
                    Foreground="{ThemeResource SystemAccentColor}" />
                <Grid Grid.Row="1" Margin="0,4">
                    <TextBlock Text="ID" />
                    <TextBlock x:Name="SelectedSystemIDTextBlock" HorizontalAlignment="Right" />
                </Grid>
                <Grid Grid.Row="2" Margin="0,4">
                    <TextBlock Text="{StaticResource MapPage_SelectedSystem_Security}" />
                    <TextBlock x:Name="SelectedSystemSecurityTextBlock" HorizontalAlignment="Right" />
                </Grid>
                <Grid Grid.Row="3" Margin="0,4">
                    <TextBlock Text="{StaticResource MapPage_SelectedSystem_Region}" />
                    <TextBlock x:Name="SelectedSystemRegionTextBlock" HorizontalAlignment="Right" />
                </Grid>
                <Grid
                    x:Name="SelectedSystemSOVGrid"
                    Grid.Row="4"
                    Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <TextBlock VerticalAlignment="Center" Text="{StaticResource MapPage_SelectedSystem_SOV}" />
                    <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                        <TextBlock x:Name="SelectedSystemSOVNameTextBlock" TextAlignment="Right" />
                        <TextBlock
                            x:Name="SelectedSystemSOVIDTextBlock"
                            FontSize="12"
                            TextAlignment="Right" />
                    </StackPanel>
                </Grid>
                <Grid x:Name="SelectedSystemResourceGrid" Grid.Row="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0,4">
                        <TextBlock Text="{StaticResource MapPage_PlanetResource_Power}" />
                        <TextBlock x:Name="SelectedSystemPowerTextBlock" HorizontalAlignment="Right" />
                    </Grid>
                    <Grid Grid.Row="1" Margin="0,4">
                        <TextBlock Text="{StaticResource MapPage_PlanetResource_Workforce}" />
                        <TextBlock x:Name="SelectedSystemWorkforceTextBlock" HorizontalAlignment="Right" />
                    </Grid>
                    <Grid Grid.Row="2" Margin="0,4">
                        <TextBlock Text="{StaticResource MapPage_PlanetResource_MagmaticGas}" />
                        <TextBlock x:Name="SelectedSystemMagmaticGasTextBlock" HorizontalAlignment="Right" />
                    </Grid>
                    <Grid Grid.Row="3" Margin="0,4">
                        <TextBlock Text="{StaticResource MapPage_PlanetResource_SuperionicIce}" />
                        <TextBlock x:Name="SelectedSystemSuperionicIceTextBlock" HorizontalAlignment="Right" />
                    </Grid>
                </Grid>
                <Grid Grid.Row="6" Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Button
                        x:Name="SystemResourceDetailButton"
                        Margin="0,0,4,0"
                        HorizontalAlignment="Stretch"
                        Click="SystemResourceDetailButton_Click">
                        <Button.Content>
                            <TextBlock
                                Padding="2"
                                FontFamily="Segoe MDL2 Assets"
                                FontSize="12"
                                Text="&#xE700;" />
                        </Button.Content>
                    </Button>
                    <Button
                        x:Name="CloseSelectedSystemInfoPanelButton"
                        Grid.Column="1"
                        Click="CloseSelectedSystemInfoPanelButton_Click">
                        <Button.Content>
                            <TextBlock
                                Padding="2"
                                FontFamily="Segoe MDL2 Assets"
                                FontSize="12"
                                Foreground="OrangeRed"
                                Text="&#xE106;" />
                        </Button.Content>
                    </Button>
                </Grid>
            </Grid>
        </Grid>
        <!--  顶上名称面板  -->
        <Grid
            x:Name="TopPanel"
            Margin="0,4,0,0"
            Padding="12,6"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            CornerRadius="4"
            Visibility="Collapsed">
            <TextBlock x:Name="PointedSystemName" FontSize="16" />
        </Grid>
    </Grid>
</Page>
