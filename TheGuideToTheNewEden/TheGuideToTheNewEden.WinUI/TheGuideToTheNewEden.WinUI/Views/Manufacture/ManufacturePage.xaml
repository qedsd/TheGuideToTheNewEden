<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="TheGuideToTheNewEden.WinUI.Views.Manufacture.ManufacturePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Manufacture="using:TheGuideToTheNewEden.WinUI.Views.Manufacture"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:TheGuideToTheNewEden.WinUI.Views.Manufacture"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="Transparent"
    NavigationCacheMode="Required"
    mc:Ignorable="d">

    <Pivot Margin="-8,-16,-8,0">

        <PivotItem>
            <PivotItem.Header>
                <TextBlock FontSize="14" Text="{StaticResource ManufacturePage_Reaction}" />
            </PivotItem.Header>
            <Manufacture:ReactionPage x:Name="ReactionPage" />
        </PivotItem>
    </Pivot>
</Page>
