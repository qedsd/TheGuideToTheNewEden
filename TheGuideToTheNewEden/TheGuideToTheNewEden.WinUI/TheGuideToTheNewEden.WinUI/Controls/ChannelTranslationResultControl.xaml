<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="TheGuideToTheNewEden.WinUI.Controls.ChannelTranslationResultControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ic="using:FluentIcons.WinUI"
    xmlns:local="using:TheGuideToTheNewEden.WinUI.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <UserControl.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal">
                <TextBlock
                    x:Name="Speaker"
                    FontSize="14"
                    FontWeight="Bold" />
                <TextBlock x:Name="SpeakTime" Margin="8,0,0,0" />
                <TextBlock
                    x:Name="SpeakLang"
                    Margin="8,0,0,0"
                    FontSize="12"
                    Foreground="{ThemeResource SecondaryForegroundBrush}" />
            </StackPanel>
            <Button
                x:Name="ShowFromButton"
                Grid.Column="1"
                Click="ShowFromButton_Click"
                FontSize="12"
                Style="{ThemeResource TransparentButton}">
                <ic:FluentIcon
                    Icon="Translate"
                    IconSize="Resizable"
                    IconVariant="Regular" />
            </Button>
        </Grid>
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid x:Name="OriginalArea">
                <TextBlock
                    x:Name="OriginalTextBlock"
                    FontSize="13"
                    Foreground="{ThemeResource SecondaryForegroundBrush}"
                    IsTextSelectionEnabled="True"
                    TextWrapping="Wrap" />
            </Grid>
            <TextBlock
                x:Name="TranslatedTextBlock"
                Grid.Row="1"
                Margin="0,4"
                IsTextSelectionEnabled="True"
                TextWrapping="Wrap" />
        </Grid>
        <Rectangle
            Grid.Row="2"
            Height="1"
            Margin="0,8,0,8"
            Fill="{ThemeResource GrayBrush}" />
    </Grid>
</UserControl>
