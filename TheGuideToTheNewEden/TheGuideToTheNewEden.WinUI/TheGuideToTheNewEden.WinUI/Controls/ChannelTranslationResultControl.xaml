<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="TheGuideToTheNewEden.WinUI.Controls.ChannelTranslationResultControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:TheGuideToTheNewEden.WinUI.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="Speaker" />
                <TextBlock
                    x:Name="SpeakTime"
                    Margin="8,0,0,0"
                    FontSize="10"
                    Foreground="{ThemeResource SecondaryForegroundBrush}" />
                <TextBlock
                    x:Name="SpeakLang"
                    Margin="8,0,0,0"
                    FontSize="10"
                    Foreground="{ThemeResource SecondaryForegroundBrush}" />
            </StackPanel>
            <Button
                x:Name="ShowFromButton"
                Grid.Column="1"
                Click="ShowFromButton_Click"
                Content="{StaticResource ChannelTranslation_Win_ShowFrom}"
                Style="{ThemeResource TransparentButton}" />
        </Grid>
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid x:Name="OriginalArea" Margin="0,0,0,8">
                <TextBox x:Name="OriginalTextBox" IsReadOnly="True" />
            </Grid>
            <TextBox x:Name="TranslatedTextBox" IsReadOnly="True" />
        </Grid>
    </Grid>
</UserControl>
