<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="TheGuideToTheNewEden.WinUI.Controls.GamePreviewGroupHotKeyControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:TheGuideToTheNewEden.WinUI.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Margin="0,4,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <StackPanel>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Center" Text="{StaticResource GamePreviewMgrPage_Forward}" />
                <TextBox
                    x:Name="ForwardTextBox"
                    Grid.Column="1"
                    Margin="8,0,8,0"
                    PlaceholderText="{StaticResource GamePreviewMgrPage_SwitchHotkey_FormatTip}" />
            </Grid>
            <Grid Margin="0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Center" Text="{StaticResource GamePreviewMgrPage_Backward}" />
                <TextBox
                    x:Name="BackwardTextBox"
                    Grid.Column="1"
                    Margin="8,0,8,0"
                    PlaceholderText="{StaticResource GamePreviewMgrPage_SwitchHotkey_FormatTip}" />
            </Grid>
        </StackPanel>
        <Grid
            Grid.Row="1"
            Height="200"
            Margin="0,4"
            CornerRadius="4">
            <ListBox x:Name="GameNameListBox" SelectionMode="Single" />
            <Grid x:Name="EditingGrid" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition />
                </Grid.RowDefinitions>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <TextBlock VerticalAlignment="Center" Text="{StaticResource GamePreviewMgrPage_GroupHotkey_Name}" />
                    <TextBox
                        x:Name="NameTextBox"
                        Grid.Column="1"
                        Margin="8,0,0,0" />
                </Grid>
                <TextBox
                    x:Name="EditingBox"
                    Grid.Row="1"
                    Margin="0,8,0,0"
                    AcceptsReturn="True"
                    PlaceholderText="{StaticResource GamePreviewMgrPage_GroupHotkey_EditTip}"
                    TextWrapping="Wrap" />
            </Grid>
        </Grid>
        <Grid Grid.Row="2" HorizontalAlignment="Right">
            <StackPanel x:Name="NormalPanel" Orientation="Horizontal">
                <Button
                    x:Name="EditGameName"
                    Margin="0,0,8,0"
                    Click="EditGameName_Click"
                    Content="{StaticResource General_Edit}" />
                <Button
                    x:Name="SaveEdit"
                    Click="SaveEdit_Click"
                    Content="{StaticResource General_Save}" />
            </StackPanel>
            <StackPanel
                x:Name="EditingPanel"
                Orientation="Horizontal"
                Visibility="Collapsed">
                <Button
                    x:Name="CancelEdit"
                    Margin="0,0,8,0"
                    Click="CancelEdit_Click"
                    Content="{StaticResource General_Cancel}" />
                <Button
                    x:Name="ConfirmEdit"
                    Click="ConfirmEdit_Click"
                    Content="{StaticResource General_OK}" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
