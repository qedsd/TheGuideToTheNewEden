<UserControl
    x:Class="TheGuideToTheNewEden.WinUI.Controls.MarketSelecteTreeControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dbmodels="using:TheGuideToTheNewEden.Core.DBModels"
    xmlns:local="using:TheGuideToTheNewEden.WinUI.Controls"
    xmlns:market="using:TheGuideToTheNewEden.Core.Models.Market"
    xmlns:market1="using:TheGuideToTheNewEden.WinUI.Models"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:treeView="using:Syncfusion.UI.Xaml.TreeView"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <TextBox
            x:Name="SearchTextBox"
            Margin="8,0"
            TextChanged="SearchTextBox_TextChanged" />
        <ScrollViewer
            x:Name="TreeList"
            Grid.Row="1"
            Margin="0,8,0,0"
            HorizontalScrollBarVisibility="Auto">
            <Grid>
                <TreeView
                    x:Name="TreeView_Types"
                    ItemInvoked="TreeView_Types_ItemInvoked"
                    SelectionMode="None">
                    <TreeView.ItemTemplate>
                        <DataTemplate x:DataType="market:SelectableMarketItem">
                            <TreeViewItem ItemsSource="{x:Bind Children}">
                                <TreeViewItem.ContentTemplate>
                                    <DataTemplate x:DataType="market:SelectableMarketItem">
                                        <Grid>
                                            <local:CheckBoxControl IsChecked="{Binding Selected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsThreeState="{Binding IsGroup}" />
                                            <TextBlock
                                                Padding="28,8,0,8"
                                                VerticalAlignment="Center"
                                                Text="{Binding Name}" />
                                            <TextBlock HorizontalAlignment="Right" Text="{Binding RealId}" />
                                        </Grid>
                                    </DataTemplate>
                                </TreeViewItem.ContentTemplate>
                            </TreeViewItem>
                        </DataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
                <treeView:SfTreeView
                    x:Name="TypesTreeView"
                    AllowEditing="False"
                    AutoExpandMode="None"
                    ChildPropertyName="Children"
                    ExpandActionTrigger="Node"
                    FullRowSelect="True"
                    IsAnimationEnabled="False"
                    ScrollViewer.IsVerticalRailEnabled="True"
                    SelectionMode="None"
                    ShowLines="False"
                    ShowRootLines="True"
                    Visibility="Collapsed">
                    <treeView:SfTreeView.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <CheckBox
                                    Content="{Binding Name}"
                                    IsChecked="{Binding Selected, Mode=TwoWay}"
                                    IsThreeState="{Binding Children, Converter={StaticResource NullToFalseConverter}}" />
                                <!--<TextBlock
                                    Margin="28,0,0,0"
                                    VerticalAlignment="Center"
                                    Text="{Binding Name}" />-->
                            </Grid>
                        </DataTemplate>
                    </treeView:SfTreeView.ItemTemplate>
                </treeView:SfTreeView>
            </Grid>
        </ScrollViewer>
        <ListView
            x:Name="SerachList"
            Grid.Row="1"
            Margin="4,4,4,0"
            Background="{ThemeResource DefaultBackgroudBrush}"
            IsItemClickEnabled="True"
            ItemClick="SerachList_ItemClick"
            SelectionMode="Single"
            Visibility="Collapsed">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <CheckBox IsChecked="{Binding Selected, Mode=TwoWay}" />
                        <TextBlock
                            Padding="28,0,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Text="{Binding Name}" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</UserControl>
