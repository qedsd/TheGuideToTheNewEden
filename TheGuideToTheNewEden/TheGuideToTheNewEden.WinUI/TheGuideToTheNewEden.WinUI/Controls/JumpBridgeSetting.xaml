<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="TheGuideToTheNewEden.WinUI.Controls.JumpBridgeSetting"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:TheGuideToTheNewEden.WinUI.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ToggleSwitch
                x:Name="ShowToggleSwitch"
                OffContent="{StaticResource JumpBridgeSetting_ShowInMap_False}"
                OnContent="{StaticResource JumpBridgeSetting_ShowInMap_True}" />
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Click="Button_Output_Click" ToolTipService.ToolTip="{StaticResource JumpBridgeSetting_Output}">
                    <TextBlock
                        VerticalAlignment="Center"
                        FontFamily="Segoe MDL2 Assets"
                        Text="&#xE72D;" />
                </Button>
                <Button
                    Margin="4,0,0,0"
                    Click="Button_Input_Click"
                    ToolTipService.ToolTip="{StaticResource JumpBridgeSetting_Input}">
                    <TextBlock
                        VerticalAlignment="Center"
                        FontFamily="Segoe MDL2 Assets"
                        Text="&#xE8F4;" />
                </Button>
            </StackPanel>
        </Grid>
        <ListView
            x:Name="BridgeList"
            Grid.Row="1"
            Margin="0,8"
            BorderBrush="LightGray"
            BorderThickness="1"
            Style="{StaticResource StretchListView}">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Text="{Binding Item1.SolarSystemName}"
                            ToolTipService.ToolTip="{Binding Item1.SolarSystemID}" />
                        <TextBlock
                            Grid.Column="1"
                            Margin="4,0,4,4"
                            VerticalAlignment="Center"
                            FontSize="30"
                            Opacity="0.5"
                            Text="↔" />
                        <TextBlock
                            Grid.Column="2"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Text="{Binding Item2.SolarSystemName}"
                            ToolTipService.ToolTip="{Binding Item2.SolarSystemID}" />
                        <Button
                            Grid.Column="3"
                            Click="Button_Remove_Click"
                            Style="{StaticResource TransparentButton}">
                            <TextBlock
                                FontFamily="Segoe MDL2 Assets"
                                FontSize="12"
                                Foreground="OrangeRed"
                                Text="&#xE106;" />
                        </Button>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid
                x:Name="AddingGrid2"
                Margin="0,8"
                Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <Button
                    x:Name="New1"
                    Height="32"
                    HorizontalAlignment="Stretch"
                    Content="{StaticResource JumpBridgeSetting_SelectSystem}">
                    <Button.Flyout>
                        <Flyout>
                            <Grid Width="300" Height="400">
                                <local:MapSystemSelectorControl OnSelectedItemChanged="MapSystemSelectorControl_OnSelectedItemChanged_1" ShowSpecial="False" />
                            </Grid>
                        </Flyout>
                    </Button.Flyout>
                </Button>
                <TextBlock
                    Grid.Column="1"
                    Margin="4,0,4,8"
                    VerticalAlignment="Top"
                    FontSize="30"
                    Text="↔" />
                <Button
                    x:Name="New2"
                    Grid.Column="2"
                    Height="32"
                    HorizontalAlignment="Stretch"
                    Content="{StaticResource JumpBridgeSetting_SelectSystem}">
                    <Button.Flyout>
                        <Flyout>
                            <Grid Width="300" Height="400">
                                <local:MapSystemSelectorControl OnSelectedItemChanged="MapSystemSelectorControl_OnSelectedItemChanged_2" ShowSpecial="False" />
                            </Grid>
                        </Flyout>
                    </Button.Flyout>
                </Button>
            </Grid>
            <Grid
                x:Name="AddGrid"
                Grid.Row="1"
                Grid.Column="1">
                <Button HorizontalAlignment="Stretch" Click="Button_Add_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock
                            VerticalAlignment="Center"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="12"
                            Foreground="MediumSeaGreen"
                            Text="&#xE109;" />
                        <TextBlock
                            Margin="8,0,0,0"
                            VerticalAlignment="Center"
                            Text="{StaticResource General_Add}" />
                    </StackPanel>
                </Button>
            </Grid>
            <Grid
                x:Name="AddingGrid1"
                Grid.Row="1"
                Grid.Column="1"
                Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <Button
                    Grid.Column="0"
                    Margin="0,0,4,0"
                    HorizontalAlignment="Stretch"
                    Click="Button_ConfirmAdd_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock
                            VerticalAlignment="Center"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="12"
                            Foreground="MediumSeaGreen"
                            Text="" />
                        <TextBlock
                            Margin="8,0,0,0"
                            VerticalAlignment="Center"
                            Text="{StaticResource General_OK}" />
                    </StackPanel>
                </Button>
                <Button
                    Grid.Column="1"
                    Margin="4,0,0,0"
                    HorizontalAlignment="Stretch"
                    Click="Button_CancelAdd_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock
                            VerticalAlignment="Center"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="12"
                            Foreground="OrangeRed"
                            Text="" />
                        <TextBlock
                            Margin="8,0,0,0"
                            VerticalAlignment="Center"
                            Text="{StaticResource General_Cancel}" />
                    </StackPanel>
                </Button>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
